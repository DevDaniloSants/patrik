{% doc %}
  @prompt
    preciso criar uma section exatamente igual ao text with image, que eu possa diminuir e aumentar o titulo e o texto e que o texto possa vir antes da imagem no mobile, a imagem precisa ficar na horizontal, tamanho menor. preciso conseguir ajustar isso. preciso conseguir centralizar o texto também
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-image-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-text-image-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {% if block.settings.image_position == 'left' %}{{ block.settings.image_width }}% 1fr{% else %}1fr {{ block.settings.image_width }}%{% endif %};
    gap: {{ block.settings.spacing }}px;
    align-items: center;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  }

  .ai-text-image-content-{{ ai_gen_id }} {
    order: {% if block.settings.image_position == 'left' %}2{% else %}1{% endif %};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-text-image-media-{{ ai_gen_id }} {
    order: {% if block.settings.image_position == 'left' %}1{% else %}2{% endif %};
    width: 100%;
  }

  .ai-text-image-media-{{ ai_gen_id }} img {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    object-fit: cover;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-text-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-text-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-text-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-text-image-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    line-height: 1.2;
  }

  .ai-text-image-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-text-image-text-{{ ai_gen_id }} p {
    margin: 0 0 1em;
  }

  .ai-text-image-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-text-image-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.spacing_mobile }}px;
    }

    .ai-text-image-content-{{ ai_gen_id }} {
      order: {% if block.settings.mobile_text_first %}1{% else %}2{% endif %};
      text-align: {{ block.settings.text_alignment_mobile }};
    }

    .ai-text-image-media-{{ ai_gen_id }} {
      order: {% if block.settings.mobile_text_first %}2{% else %}1{% endif %};
    }

    .ai-text-image-media-{{ ai_gen_id }} img {
      height: {{ block.settings.image_height_mobile }}px;
    }

    .ai-text-image-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.image_height_mobile }}px;
    }

    .ai-text-image-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-text-image-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-text-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-image-container-{{ ai_gen_id }}">
    <div class="ai-text-image-content-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-text-image-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.text != blank %}
        <div class="ai-text-image-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}
    </div>

    <div class="ai-text-image-media-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
        >
      {% else %}
        <div class="ai-text-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-text-image-empty-state-{{ ai_gen_id }}">
            Adicione uma imagem
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Texto com imagem",
  "settings": [
    {
      "type": "header",
      "content": "Conteúdo"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Título",
      "default": "Texto com imagem"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Combine texto e imagens para criar uma seção impactante e informativa.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagem"
    },
    {
      "type": "header",
      "content": "Layout desktop"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Posição da imagem",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Largura da imagem",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Altura da imagem desktop",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largura máxima",
      "min": 600,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Espaçamento entre colunas",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alinhamento do texto",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Layout mobile"
    },
    {
      "type": "checkbox",
      "id": "mobile_text_first",
      "label": "Texto antes da imagem no mobile",
      "default": false
    },
    {
      "type": "range",
      "id": "image_height_mobile",
      "label": "Altura da imagem mobile",
      "min": 150,
      "max": 500,
      "step": 25,
      "unit": "px",
      "default": 250
    },
    {
      "type": "range",
      "id": "spacing_mobile",
      "label": "Espaçamento no mobile",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "label": "Alinhamento do texto mobile",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Tamanho do título"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Desktop",
      "min": 16,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Mobile",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Espaçamento abaixo do título",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Tamanho do texto"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Desktop",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Mobile",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Cores"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Cor do título",
      "default": "#3c3f36"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#3c3f36"
    },
    {
      "type": "header",
      "content": "Espaçamento"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espaçamento superior",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espaçamento inferior",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Espaçamento lateral",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Estilo da imagem"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Arredondamento da imagem",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Texto com imagem"
    }
  ]
}
{% endschema %}