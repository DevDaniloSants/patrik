{% doc %}
  @prompt
    um slider para eu incluir manualmente relatos de clientes, sem imagens, apenas texto e possa adicionar quantos eu quiser, além poder ir para o lado para ver os próximos comentarios 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-slider-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    position: relative;
    overflow: hidden;
    padding: 40px 0;
    display: block;
  }

  .ai-testimonial-slider__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-testimonial-slider__track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-testimonial-slider__slide-{{ ai_gen_id }} {
    min-width: 100%;
    flex-shrink: 0;
    padding: {{ block.settings.card_padding }}px;
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-sizing: border-box;
  }

  .ai-testimonial-slider__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .ai-testimonial-slider__author-{{ ai_gen_id }} {
    color: {{ block.settings.author_color }};
    font-size: {{ block.settings.author_size }}px;
    font-weight: 600;
  }

  .ai-testimonial-slider__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
  }

  .ai-testimonial-slider__button-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_color }};
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .ai-testimonial-slider__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-testimonial-slider__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-testimonial-slider__button-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-testimonial-slider__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-testimonial-slider__dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.3;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-testimonial-slider__dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-testimonial-slider__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 16px;
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-slider-{{ ai_gen_id }} {
      padding: 20px 0;
    }

    .ai-testimonial-slider__slide-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.7 }}px;
    }

    .ai-testimonial-slider__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-testimonial-slider__author-{{ ai_gen_id }} {
      font-size: {{ block.settings.author_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<testimonial-slider-{{ ai_gen_id }} class="ai-testimonial-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% assign testimonial_count = 0 %}
  {% for i in (1..10) %}
    {% assign text_key = 'testimonial_' | append: i | append: '_text' %}
    {% assign author_key = 'testimonial_' | append: i | append: '_author' %}
    {% if block.settings[text_key] != blank %}
      {% assign testimonial_count = testimonial_count | plus: 1 %}
    {% endif %}
  {% endfor %}

  {% if testimonial_count > 0 %}
    <div class="ai-testimonial-slider__container-{{ ai_gen_id }}">
      <div class="ai-testimonial-slider__track-{{ ai_gen_id }}">
        {% for i in (1..10) %}
          {% assign text_key = 'testimonial_' | append: i | append: '_text' %}
          {% assign author_key = 'testimonial_' | append: i | append: '_author' %}
          {% assign testimonial_text = block.settings[text_key] %}
          {% assign testimonial_author = block.settings[author_key] %}

          {% if testimonial_text != blank %}
            <div class="ai-testimonial-slider__slide-{{ ai_gen_id }}">
              <div class="ai-testimonial-slider__text-{{ ai_gen_id }}">
                {{ testimonial_text }}
              </div>
              {% if testimonial_author != blank %}
                <div class="ai-testimonial-slider__author-{{ ai_gen_id }}">
                  {{ testimonial_author }}
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if testimonial_count > 1 %}
        <div class="ai-testimonial-slider__controls-{{ ai_gen_id }}">
          <button
            class="ai-testimonial-slider__button-{{ ai_gen_id }} ai-testimonial-slider__prev-{{ ai_gen_id }}"
            aria-label="Depoimento anterior"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>

          <div class="ai-testimonial-slider__dots-{{ ai_gen_id }}">
            {% for i in (1..testimonial_count) %}
              <button
                class="ai-testimonial-slider__dot-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
                data-index="{{ i | minus: 1 }}"
                aria-label="Ir para depoimento {{ i }}"
              ></button>
            {% endfor %}
          </div>

          <button
            class="ai-testimonial-slider__button-{{ ai_gen_id }} ai-testimonial-slider__next-{{ ai_gen_id }}"
            aria-label="Próximo depoimento"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      {% endif %}
    </div>
  {% else %}
    <div class="ai-testimonial-slider__empty-{{ ai_gen_id }}">
      Adicione depoimentos de clientes nas configurações do bloco
    </div>
  {% endif %}
</testimonial-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.totalSlides = 0;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-testimonial-slider__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-testimonial-slider__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-testimonial-slider__prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-testimonial-slider__next-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-testimonial-slider__dot-{{ ai_gen_id }}');

        this.totalSlides = this.slides.length;

        if (this.totalSlides <= 1) return;

        this.setupEventListeners();
        this.updateSlider();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.goToPrev());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.goToNext());
        }

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const index = parseInt(e.target.dataset.index);
            this.goToSlide(index);
          });
        });

        let startX = 0;
        let currentX = 0;
        let isDragging = false;

        this.track.addEventListener('touchstart', (e) => {
          startX = e.touches[0].clientX;
          isDragging = true;
        });

        this.track.addEventListener('touchmove', (e) => {
          if (!isDragging) return;
          currentX = e.touches[0].clientX;
        });

        this.track.addEventListener('touchend', () => {
          if (!isDragging) return;
          isDragging = false;

          const diff = startX - currentX;

          if (Math.abs(diff) > 50) {
            if (diff > 0) {
              this.goToNext();
            } else {
              this.goToPrev();
            }
          }
        });
      }

      goToPrev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateSlider();
        }
      }

      goToNext() {
        if (this.currentIndex < this.totalSlides - 1) {
          this.currentIndex++;
          this.updateSlider();
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateSlider();
      }

      updateSlider() {
        const offset = -this.currentIndex * 100;
        this.track.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });

        if (this.prevButton) {
          this.prevButton.disabled = this.currentIndex === 0;
        }

        if (this.nextButton) {
          this.nextButton.disabled = this.currentIndex === this.totalSlides - 1;
        }
      }
    }

    customElements.define('testimonial-slider-{{ ai_gen_id }}', TestimonialSlider{{ ai_gen_id }});
  })();
</script>

