{% doc %}
  @prompt
    um cronometro onde eu consiga setar a data dentro do banner
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-timer-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
  }

  .ai-countdown-timer__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.spacing }}px 0;
  }

  .ai-countdown-timer__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 {{ block.settings.spacing }}px 0;
    opacity: 0.9;
  }

  .ai-countdown-timer__display-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: {{ block.settings.unit_spacing }}px;
    flex-wrap: wrap;
  }

  .ai-countdown-timer__unit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: {{ block.settings.unit_width }}px;
  }

  .ai-countdown-timer__number-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: bold;
    color: {{ block.settings.number_color }};
    line-height: 1;
    margin-bottom: 8px;
  }

  .ai-countdown-timer__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subheading_size }}px;
    display: none;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }}.active {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-timer__number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.number_size }}px * 0.7);
    }

    .ai-countdown-timer__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-countdown-timer__unit-{{ ai_gen_id }} {
      min-width: calc({{ block.settings.unit_width }}px * 0.8);
    }
  }
{% endstyle %}

<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-countdown-timer__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.subheading != blank %}
    <p class="ai-countdown-timer__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
  {% endif %}

  <div class="ai-countdown-timer__display-{{ ai_gen_id }}">
    {% if block.settings.show_days %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-days>00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.label_days }}</div>
      </div>
    {% endif %}

    {% if block.settings.show_hours %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-hours>00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.label_hours }}</div>
      </div>
    {% endif %}

    {% if block.settings.show_minutes %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-minutes>00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.label_minutes }}</div>
      </div>
    {% endif %}

    {% if block.settings.show_seconds %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-seconds>00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.label_seconds }}</div>
      </div>
    {% endif %}
  </div>

  <div class="ai-countdown-timer__expired-{{ ai_gen_id }}">
    {{ block.settings.expired_message }}
  </div>
</countdown-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.interval = null;
      }

      connectedCallback() {
        this.daysEl = this.querySelector('[data-days]');
        this.hoursEl = this.querySelector('[data-hours]');
        this.minutesEl = this.querySelector('[data-minutes]');
        this.secondsEl = this.querySelector('[data-seconds]');
        this.expiredEl = this.querySelector('.ai-countdown-timer__expired-{{ ai_gen_id }}');
        this.displayEl = this.querySelector('.ai-countdown-timer__display-{{ ai_gen_id }}');

        if (!this.endDate) {
          return;
        }

        this.startCountdown();
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      startCountdown() {
        this.updateCountdown();
        this.interval = setInterval(() => this.updateCountdown(), 1000);
      }

      updateCountdown() {
        const dateTimeString = this.endTime 
          ? `${this.endDate}T${this.endTime}` 
          : `${this.endDate}T23:59:59`;
        
        const endDateTime = new Date(dateTimeString).getTime();
        const now = new Date().getTime();
        const distance = endDateTime - now;

        if (distance < 0) {
          clearInterval(this.interval);
          this.showExpired();
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        if (this.daysEl) this.daysEl.textContent = String(days).padStart(2, '0');
        if (this.hoursEl) this.hoursEl.textContent = String(hours).padStart(2, '0');
        if (this.minutesEl) this.minutesEl.textContent = String(minutes).padStart(2, '0');
        if (this.secondsEl) this.secondsEl.textContent = String(seconds).padStart(2, '0');
      }

      showExpired() {
        if (this.displayEl) this.displayEl.style.display = 'none';
        if (this.expiredEl) this.expiredEl.classList.add('active');
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>

