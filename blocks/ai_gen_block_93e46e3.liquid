{% doc %}
  @prompt
    Create a clickable banner block with 11 clickable hotspot areas overlaid on a banner image. Each hotspot area should be visible with a semi-transparent colored overlay and a border so merchants can see exactly where each clickable zone is positioned. Each area should have settings for: link URL, position (top % and left %), size (width % and height %), and a label/number displayed inside the area so merchants can identify which area is which. The areas should always be visible in the theme editor to help with positioning.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-clickable-banner-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-clickable-banner__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-clickable-banner__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-clickable-banner__placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-clickable-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-clickable-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-clickable-banner__hotspot-{{ ai_gen_id }} {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: transparent;
    opacity: 1;
    border: none;
    transition: opacity 0.3s ease;
    cursor: pointer;
    text-decoration: none;
  }

  .ai-clickable-banner__hotspot-label-{{ ai_gen_id }} {
    display: none;
  }

  .shopify-design-mode .ai-clickable-banner__hotspot-{{ ai_gen_id }} {
    background-color: {{ block.settings.hotspot_overlay_color }};
    opacity: {{ block.settings.hotspot_opacity }};
    border: {{ block.settings.hotspot_border_width }}px solid {{ block.settings.hotspot_border_color }};
  }

  .shopify-design-mode .ai-clickable-banner__hotspot-{{ ai_gen_id }}:hover {
    opacity: {{ block.settings.hotspot_hover_opacity }};
  }

  .shopify-design-mode .ai-clickable-banner__hotspot-label-{{ ai_gen_id }} {
    display: block;
    font-size: {{ block.settings.label_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.label_text_color }};
    pointer-events: none;
    user-select: none;
  }
@media screen and (max-width: 749px) {
    .ai-clickable-banner-{{ ai_gen_id }} {
      width: 100%;
      overflow: hidden;
    }

    .ai-clickable-banner__image-wrapper-{{ ai_gen_id }} {
      min-width: unset;
      width: 100%;
    }

    .ai-clickable-banner__image-{{ ai_gen_id }} {
      width: 100%;
      height: auto;
    }
  }
  
{% endstyle %}

<clickable-banner-{{ ai_gen_id }}
  class="ai-clickable-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-clickable-banner__image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.banner_image %}
      <img
        src="{{ block.settings.banner_image | image_url: width: 2000 }}"
        alt="{{ block.settings.banner_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.banner_image.width }}"
        height="{{ block.settings.banner_image.height }}"
        class="ai-clickable-banner__image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-clickable-banner__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-clickable-banner__empty-state-{{ ai_gen_id }}">
          Add a banner image to get started
        </div>
      </div>
    {% endif %}

    {% for i in (1..11) %}
      {% liquid
        assign hotspot_enabled_key = 'hotspot_' | append: i | append: '_enabled'
        assign hotspot_label_key = 'hotspot_' | append: i | append: '_label'
        assign hotspot_url_key = 'hotspot_' | append: i | append: '_url'
        assign hotspot_top_key = 'hotspot_' | append: i | append: '_top'
        assign hotspot_left_key = 'hotspot_' | append: i | append: '_left'
        assign hotspot_width_key = 'hotspot_' | append: i | append: '_width'
        assign hotspot_height_key = 'hotspot_' | append: i | append: '_height'

        assign hotspot_enabled = block.settings[hotspot_enabled_key]
        assign hotspot_label = block.settings[hotspot_label_key]
        assign hotspot_url = block.settings[hotspot_url_key]
        assign hotspot_top = block.settings[hotspot_top_key]
        assign hotspot_left = block.settings[hotspot_left_key]
        assign hotspot_width = block.settings[hotspot_width_key]
        assign hotspot_height = block.settings[hotspot_height_key]
      %}

      {% if hotspot_enabled %}
        <a
          href="{{ hotspot_url }}"
          class="ai-clickable-banner__hotspot-{{ ai_gen_id }}"
          style="
            top: {{ hotspot_top }}%;
            left: {{ hotspot_left }}%;
            width: {{ hotspot_width }}%;
            height: {{ hotspot_height }}%;
          "
          aria-label="{{ hotspot_label | escape }}"
        >
          <span class="ai-clickable-banner__hotspot-label-{{ ai_gen_id }}">{{ hotspot_label }}</span>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</clickable-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class ClickableBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.hotspots = this.querySelectorAll('.ai-clickable-banner__hotspot-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.hotspots.forEach((hotspot) => {
          hotspot.addEventListener('click', (event) => {
            const url = hotspot.getAttribute('href');
            if (!url || url === '' || url === '#') {
              event.preventDefault();
            }
          });
        });
      }
    }

    customElements.define('clickable-banner-{{ ai_gen_id }}', ClickableBanner{{ ai_gen_id }});
  })();
</script>

