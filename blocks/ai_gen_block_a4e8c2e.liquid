{% doc %}
  @prompt
    um bloco onde de um lado eu vou incluir um vídeo e do outro vou incluir um texto
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
video {
  width: 100%;
  height: auto;
  display: block;
}
{% style %}
  .ai-video-text-block-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-video-text-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-video-text-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
    {% if block.settings.layout == 'video_left' %}
      flex-direction: row;
    {% else %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .ai-video-text-video-column-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.video_width }}%;
    max-width: {{ block.settings.video_width }}%;
  }

  .ai-video-text-text-column-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-video-text-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    overflow: hidden;
    border-radius: {{ block.settings.video_border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-video-text-video-wrapper-{{ ai_gen_id }} iframe,
  .ai-video-text-video-wrapper-{{ ai_gen_id }} video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-video-text-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-video-text-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-video-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-text-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
  }

  .ai-video-text-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
  }

  .ai-video-text-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-video-text-text-{{ ai_gen_id }} p {
    margin: 0 0 16px 0;
  }

  .ai-video-text-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-video-text-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-video-text-video-column-{{ ai_gen_id }},
    .ai-video-text-text-column-{{ ai_gen_id }} {
      flex: 0 0 100%;
      max-width: 100%;
    }

    .ai-video-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-video-text-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-video-text-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-text-container-{{ ai_gen_id }}">
    <div class="ai-video-text-wrapper-{{ ai_gen_id }}">
      <div class="ai-video-text-video-column-{{ ai_gen_id }}">
        <div class="ai-video-text-video-wrapper-{{ ai_gen_id }}">
          {% if block.settings.video_url != blank %}
            {% if block.settings.video_url contains 'youtube.com' or block.settings.video_url contains 'youtu.be' %}
              {% assign video_id = block.settings.video_url | split: 'v=' | last | split: '/' | last | split: '&' | first %}
              <iframe
                src="https://www.youtube.com/embed/{{ video_id }}"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            {% elsif block.settings.video_url contains 'vimeo.com' %}
              {% assign video_id = block.settings.video_url | split: '/' | last %}
              <iframe
                src="https://player.vimeo.com/video/{{ video_id }}"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            {% else %}
              <video controls>
                <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
            {% endif %}
          {% else %}
            <div class="ai-video-text-placeholder-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="5 3 19 12 5 21 5 3"></polygon>
              </svg>
              <div class="ai-video-text-empty-state-{{ ai_gen_id }}">
                Adicione um vídeo
              </div>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-video-text-text-column-{{ ai_gen_id }}">
        <div class="ai-video-text-content-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-video-text-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
          {% endif %}
          {% if block.settings.text != blank %}
            <div class="ai-video-text-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Vídeo e texto",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Posição do vídeo",
      "options": [
        {
          "value": "video_left",
          "label": "Esquerda"
        },
        {
          "value": "video_right",
          "label": "Direita"
        }
      ],
      "default": "video_left"
    },
    {
      "type": "range",
      "id": "video_width",
      "label": "Largura do vídeo",
      "min": 30,
      "max": 70,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Alinhamento vertical",
      "options": [
        {
          "value": "flex-start",
          "label": "Topo"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "flex-end",
          "label": "Base"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espaçamento entre colunas",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Vídeo"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "URL do vídeo",
      "info": "YouTube, Vimeo ou link direto para arquivo MP4"
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "label": "Arredondamento das bordas",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Texto"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Título",
      "default": "Título do bloco"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Adicione seu texto aqui. Você pode incluir informações sobre o vídeo ou qualquer outro conteúdo relevante.</p>"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Tamanho do título",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Tamanho do texto",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Espaçamento abaixo do título",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Cores"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fundo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Cor do título",
      "default": "#3c3f36"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#3c3f36"
    },
    {
      "type": "header",
      "content": "Espaçamento"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Largura máxima do container",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Espaçamento vertical",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "Espaçamento horizontal",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Vídeo e texto"
    }
  ]
}
{% endschema %}