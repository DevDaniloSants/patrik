{% doc %}
  @prompt
    uma section onde euConsigo adicionar 3 imagens que eu possa clicar e direcionar para uma nova section dentro da própria pagina
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-nav-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-image-nav-title-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin-bottom: {{ block.settings.title_margin_bottom }}px;
    padding: 0 20px;
  }

  .ai-image-nav-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: {{ block.settings.image_spacing }}px;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .ai-image-nav-container-{{ ai_gen_id }} {
      width: 100%;
      margin: 0 auto;
    }
  }

  .ai-image-nav-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-image-nav-item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-image-nav-link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    text-decoration: none;
  }

  .ai-image-nav-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio | times: 100 }}%;
    overflow: hidden;
  }

  .ai-image-nav-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-nav-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity }}) 100%
    );
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: {{ block.settings.text_padding }}px;
  }

  .ai-image-nav-btn-{{ ai_gen_id }} {
    display: inline-block;
    padding: 8px 24px;
    background-color: #ffffff;
    color: #006652;
    font-size: 16px;
    font-weight: {{ block.settings.text_weight }};
    text-align: center;
    border: none;
    border-radius: 45px;
    cursor: pointer;
    transition: background-color 0.3s ease, color 0.3s ease, opacity 0.3s ease;
    opacity: {{ block.settings.button_opacity | divided_by: 100.0 }};
  }

  .ai-image-nav-item-{{ ai_gen_id }}:hover .ai-image-nav-btn-{{ ai_gen_id }} {
    background-color: #3c3f36;
    color: #ffffff;
  }

  @media screen and (max-width: 749px) {
    .ai-image-nav-container-{{ ai_gen_id }} {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: {{ block.settings.image_spacing | times: 0.7 }}px;
      padding-bottom: 12px;
    }

    .ai-image-nav-item-{{ ai_gen_id }} {
      flex: 0 0 70%;
      scroll-snap-align: start;
    }

    .ai-image-nav-btn-{{ ai_gen_id }} {
      font-size: 13px;
      padding: 8px 16px;
    }
  }
{% endstyle %}

<image-navigator-{{ ai_gen_id }} class="ai-image-nav-{{ ai_gen_id }}" {{ block.shopify_attributes }}>

  {% if block.settings.title != blank %}
    <h2 class="ai-image-nav-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
  {% endif %}

  <div class="ai-image-nav-container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign text_key = 'text_' | append: i
        assign target_key = 'target_section_' | append: i
        assign image = block.settings[image_key]
        assign text = block.settings[text_key]
        assign target = block.settings[target_key]
      %}

      {% if image %}
        <div class="ai-image-nav-item-{{ ai_gen_id }}">
          <a
            href="#{{ target }}"
            class="ai-image-nav-link-{{ ai_gen_id }}"
            data-scroll-target="{{ target }}"
          >
            <div class="ai-image-nav-image-wrapper-{{ ai_gen_id }}">
              <img
                src="{{ image | image_url: width: 1200 }}"
                alt="{{ text | escape }}"
                loading="lazy"
                width="1200"
                height="{{ 1200 | times: block.settings.image_aspect_ratio | round }}"
                class="ai-image-nav-image-{{ ai_gen_id }}"
              >

              {% if text != blank %}
                <div class="ai-image-nav-overlay-{{ ai_gen_id }}">
                  <span class="ai-image-nav-btn-{{ ai_gen_id }}">{{ text }}</span>
                </div>
              {% endif %}
            </div>
          </a>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</image-navigator-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageNavigator{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.links = this.querySelectorAll('.ai-image-nav-link-{{ ai_gen_id }}');
        this.setupScrollNavigation();
      }

      setupScrollNavigation() {
        this.links.forEach((link) => {
          link.addEventListener('click', (e) => {
            e.preventDefault();
            const targetId = link.getAttribute('data-scroll-target');

            if (!targetId) return;

            const targetElement = document.getElementById(targetId);

            if (targetElement) {
              const offset = {{ block.settings.scroll_offset }};
              const elementPosition = targetElement.getBoundingClientRect().top;
              const offsetPosition = elementPosition + window.pageYOffset - offset;

              window.scrollTo({
                top: offsetPosition,
                behavior: 'smooth'
              });
            }
          });
        });
      }
    }

    customElements.define('image-navigator-{{ ai_gen_id }}', ImageNavigator{{ ai_gen_id }});
  })();
</script>

