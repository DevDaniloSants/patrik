{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
   {% assign ratio_str = block.settings.aspect_ratio | default: '9/16' %}
  {% assign ratio_parts = ratio_str | split: '/' %}
  {% assign ratio_w = ratio_parts[0] | times: 1.0 %}
  {% assign ratio_h = ratio_parts[1] | times: 1.0 %}
  {% assign ratio_decimal = ratio_w | divided_by: ratio_h %}

  .apv-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .apv-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .apv-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: {{ block.settings.gap }}px;
  }

  .apv-media-1-{{ ai_gen_id }} { grid-column: 1; grid-row: 1; }
  .apv-content-1-{{ ai_gen_id }} { grid-column: 2; grid-row: 1; }
  .apv-content-2-{{ ai_gen_id }} { grid-column: 1; grid-row: 2; }
  .apv-media-2-{{ ai_gen_id }} { grid-column: 2; grid-row: 2; }

  .apv-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
    align-self: start;
  }

  .apv-kicker-{{ ai_gen_id }} {
    color: {{ block.settings.kicker_color }};
    font-size: {{ block.settings.kicker_size }}px;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .apv-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0;
    line-height: 1.2;
  }

  .apv-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .apv-text-{{ ai_gen_id }} p { margin: 0 0 1em 0; }
  .apv-text-{{ ai_gen_id }} p:last-child { margin-bottom: 0; }

  .apv-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
    font-size: {{ block.settings.button_text_size }}px;
  }

  .apv-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .apv-media-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.video_width | default: 100 }}%;
    margin: 0 auto;
    overflow: hidden;
    align-self: start;
  }

  .apv-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: flex;
  }

  .apv-video-{{ ai_gen_id }} {
    width: 100%;
    max-width: calc((80vh - 50px) * {{ ratio_decimal }});
    max-height: calc(80vh - 50px);
    aspect-ratio: {{ block.settings.aspect_ratio | default: '9/16' }};
    object-fit: cover;
    display: block;
    margin: 0 auto;
  }

  .apv-play-{{ ai_gen_id }} {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 64px; height: 64px;
    background-color: rgba(0,0,0,0.6);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .apv-play-{{ ai_gen_id }}:hover {
    background-color: rgba(0,0,0,0.8);
    transform: translate(-50%, -50%) scale(1.05);
  }

  .apv-play-{{ ai_gen_id }} svg {
    width: 28px; height: 28px;
    fill: #ffffff;
    margin-left: 4px;
  }

  .apv-placeholder-{{ ai_gen_id }} {
    width: 100%;
    max-width: calc((80vh - 50px) * {{ ratio_decimal }});
    max-height: calc(80vh - 50px);
    aspect-ratio: {{ block.settings.aspect_ratio | default: '9/16' }};
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    margin: 0 auto;
  }

  @media screen and (max-width: 749px) {
    .apv-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .apv-media-1-{{ ai_gen_id }},
    .apv-content-1-{{ ai_gen_id }},
    .apv-content-2-{{ ai_gen_id }},
    .apv-media-2-{{ ai_gen_id }} {
      grid-column: 1 !important;
      grid-row: auto !important;
    }

    {% if block.settings.mobile_video_first %}
  .apv-content-1-{{ ai_gen_id }} { order: 2; }
  .apv-media-1-{{ ai_gen_id }}   { order: 1; }
  .apv-content-2-{{ ai_gen_id }} { order: 4; }
  .apv-media-2-{{ ai_gen_id }}   { order: 3; }
{% else %}
  .apv-content-1-{{ ai_gen_id }} { order: 1; }
  .apv-media-1-{{ ai_gen_id }}   { order: 2; }
  .apv-content-2-{{ ai_gen_id }} { order: 3; }
  .apv-media-2-{{ ai_gen_id }}   { order: 4; }
{% endif %}

    .apv-media-{{ ai_gen_id }} {
      margin-left: calc(-1 * {{ block.settings.horizontal_padding }}px);
      width: calc(100% + {{ block.settings.horizontal_padding | times: 2 }}px);
      border-radius: 0;
    }

    .apv-video-{{ ai_gen_id }},
    .apv-placeholder-{{ ai_gen_id }} {
      max-width: 100%;
      max-height: none;
    }

    .apv-heading-{{ ai_gen_id }} { font-size: {{ block.settings.heading_size | times: 0.7 }}px; }
    .apv-kicker-{{ ai_gen_id }}  { font-size: {{ block.settings.kicker_size | times: 0.8 }}px; }
    .apv-text-{{ ai_gen_id }}    { font-size: {{ block.settings.text_size | times: 0.9 }}px; }

        .apv-media-2-{{ ai_gen_id }} {
      margin-top: 60px;
    }

  }

{% endstyle %}

{% assign play_icon = '<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8 5V19L19 12L8 5Z" fill="currentColor"/></svg>' %}

<paired-video-section-{{ ai_gen_id }}
  class="apv-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="apv-container-{{ ai_gen_id }}">
    <div class="apv-grid-{{ ai_gen_id }}">

      {%- comment -%} ── PAR 1: Vídeo esquerda, Texto direita ── {%- endcomment -%}
      <div class="apv-media-{{ ai_gen_id }} apv-media-1-{{ ai_gen_id }}">
        <div class="apv-video-wrapper-{{ ai_gen_id }}">
          {% if block.settings.video_1 != blank %}
            {% assign vc = 'apv-video-' | append: ai_gen_id %}
            {{ block.settings.video_1 | video_tag: image_size: '2048x', class: vc, autoplay: block.settings.auto_play, loop: block.settings.loop, muted: block.settings.mute_video, controls: block.settings.show_controls, playsinline: true }}
            <div class="apv-play-{{ ai_gen_id }}">{{ play_icon }}</div>
          {% elsif block.settings.video_url_1 != blank %}
            {% if block.settings.video_url_1 contains 'youtube.com' or block.settings.video_url_1 contains 'youtu.be' %}
              {% assign vid = block.settings.video_url_1 | split: 'v=' | last | split: '/' | last | split: '?' | first | split: '&' | first %}
              {% assign ap = 0 %}{% if block.settings.auto_play %}{% assign ap = 1 %}{% endif %}
              {% assign lp = 0 %}{% if block.settings.loop %}{% assign lp = 1 %}{% endif %}
              {% assign mu = 0 %}{% if block.settings.mute_video %}{% assign mu = 1 %}{% endif %}
              {% assign ct = 0 %}{% if block.settings.show_controls %}{% assign ct = 1 %}{% endif %}
              <iframe class="apv-video-{{ ai_gen_id }}" src="https://www.youtube.com/embed/{{ vid }}?autoplay={{ ap }}&loop={{ lp }}&mute={{ mu }}&controls={{ ct }}&playlist={{ vid }}" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
            {% elsif block.settings.video_url_1 contains 'vimeo.com' %}
              {% assign vid = block.settings.video_url_1 | split: '/' | last | split: '?' | first %}
              {% assign ap = 0 %}{% if block.settings.auto_play %}{% assign ap = 1 %}{% endif %}
              {% assign lp = 0 %}{% if block.settings.loop %}{% assign lp = 1 %}{% endif %}
              {% assign mu = 0 %}{% if block.settings.mute_video %}{% assign mu = 1 %}{% endif %}
              <iframe class="apv-video-{{ ai_gen_id }}" src="https://player.vimeo.com/video/{{ vid }}?autoplay={{ ap }}&loop={{ lp }}&muted={{ mu }}" frameborder="0" allow="autoplay; fullscreen" allowfullscreen></iframe>
            {% endif %}
          {% else %}
            <div class="apv-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}</div>
          {% endif %}
        </div>
      </div>

      <div class="apv-content-{{ ai_gen_id }} apv-content-1-{{ ai_gen_id }}">
        {% if block.settings.kicker_1 != blank %}<p class="apv-kicker-{{ ai_gen_id }}">{{ block.settings.kicker_1 }}</p>{% endif %}
        {% if block.settings.heading_1 != blank %}<h2 class="apv-heading-{{ ai_gen_id }}">{{ block.settings.heading_1 }}</h2>{% endif %}
        {% if block.settings.text_1 != blank %}<div class="apv-text-{{ ai_gen_id }}">{{ block.settings.text_1 }}</div>{% endif %}
        {% if block.settings.button_text_1 != blank and block.settings.button_link_1 != blank %}
          <div><a href="{{ block.settings.button_link_1 }}" class="apv-button-{{ ai_gen_id }}">{{ block.settings.button_text_1 }}</a></div>
        {% endif %}
      </div>

      {%- comment -%} ── PAR 2: Texto esquerda, Vídeo direita ── {%- endcomment -%}
      <div class="apv-content-{{ ai_gen_id }} apv-content-2-{{ ai_gen_id }}">
        {% if block.settings.kicker_2 != blank %}<p class="apv-kicker-{{ ai_gen_id }}">{{ block.settings.kicker_2 }}</p>{% endif %}
        {% if block.settings.heading_2 != blank %}<h2 class="apv-heading-{{ ai_gen_id }}">{{ block.settings.heading_2 }}</h2>{% endif %}
        {% if block.settings.text_2 != blank %}<div class="apv-text-{{ ai_gen_id }}">{{ block.settings.text_2 }}</div>{% endif %}
        {% if block.settings.button_text_2 != blank and block.settings.button_link_2 != blank %}
          <div><a href="{{ block.settings.button_link_2 }}" class="apv-button-{{ ai_gen_id }}">{{ block.settings.button_text_2 }}</a></div>
        {% endif %}
      </div>

      <div class="apv-media-{{ ai_gen_id }} apv-media-2-{{ ai_gen_id }}">
        <div class="apv-video-wrapper-{{ ai_gen_id }}">
          {% if block.settings.video_2 != blank %}
            {% assign vc = 'apv-video-' | append: ai_gen_id %}
            {{ block.settings.video_2 | video_tag: image_size: '2048x', class: vc, autoplay: block.settings.auto_play, loop: block.settings.loop, muted: block.settings.mute_video, controls: block.settings.show_controls, playsinline: true }}
            <div class="apv-play-{{ ai_gen_id }}">{{ play_icon }}</div>
          {% elsif block.settings.video_url_2 != blank %}
            {% if block.settings.video_url_2 contains 'youtube.com' or block.settings.video_url_2 contains 'youtu.be' %}
              {% assign vid = block.settings.video_url_2 | split: 'v=' | last | split: '/' | last | split: '?' | first | split: '&' | first %}
              {% assign ap = 0 %}{% if block.settings.auto_play %}{% assign ap = 1 %}{% endif %}
              {% assign lp = 0 %}{% if block.settings.loop %}{% assign lp = 1 %}{% endif %}
              {% assign mu = 0 %}{% if block.settings.mute_video %}{% assign mu = 1 %}{% endif %}
              {% assign ct = 0 %}{% if block.settings.show_controls %}{% assign ct = 1 %}{% endif %}
              <iframe class="apv-video-{{ ai_gen_id }}" src="https://www.youtube.com/embed/{{ vid }}?autoplay={{ ap }}&loop={{ lp }}&mute={{ mu }}&controls={{ ct }}&playlist={{ vid }}" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
            {% elsif block.settings.video_url_2 contains 'vimeo.com' %}
              {% assign vid = block.settings.video_url_2 | split: '/' | last | split: '?' | first %}
              {% assign ap = 0 %}{% if block.settings.auto_play %}{% assign ap = 1 %}{% endif %}
              {% assign lp = 0 %}{% if block.settings.loop %}{% assign lp = 1 %}{% endif %}
              {% assign mu = 0 %}{% if block.settings.mute_video %}{% assign mu = 1 %}{% endif %}
              <iframe class="apv-video-{{ ai_gen_id }}" src="https://player.vimeo.com/video/{{ vid }}?autoplay={{ ap }}&loop={{ lp }}&muted={{ mu }}" frameborder="0" allow="autoplay; fullscreen" allowfullscreen></iframe>
            {% endif %}
          {% else %}
            <div class="apv-placeholder-{{ ai_gen_id }}">{{ 'image' | placeholder_svg_tag }}</div>
          {% endif %}
        </div>
      </div>

    </div>
  </div>
</paired-video-section-{{ ai_gen_id }}>

<script>
(function() {
  class PairedVideoSection{{ ai_gen_id }} extends HTMLElement {
    connectedCallback() {
      this.querySelectorAll('.apv-video-{{ ai_gen_id }}').forEach((video, i) => {
        if (video.tagName !== 'VIDEO') return;
        const playBtn = this.querySelectorAll('.apv-play-{{ ai_gen_id }}')[i];
        {% if block.settings.auto_play %}
          new IntersectionObserver((entries) => {
            entries.forEach(e => {
              if (e.isIntersecting) video.play().catch(()=>{});
              else video.pause();
            });
          }, { threshold: 0.5 }).observe(video);
        {% endif %}
        if (playBtn) {
          if (!video.paused) playBtn.style.display = 'none';
          playBtn.addEventListener('click', () => video.play());
          video.addEventListener('play', () => playBtn.style.display = 'none');
          video.addEventListener('pause', () => playBtn.style.display = 'flex');
        }
      });
    }
  }
  customElements.define('paired-video-section-{{ ai_gen_id }}', PairedVideoSection{{ ai_gen_id }});
})();
</script>

{% schema %}
{
  "name": "Par de vídeo e texto",
  "settings": [
    { "type": "header", "content": "Par 1 — Conteúdo" },
    { "type": "text", "id": "kicker_1", "label": "Texto superior" },
    { "type": "text", "id": "heading_1", "label": "Título", "default": "Título 1" },
    { "type": "richtext", "id": "text_1", "label": "Texto", "default": "<p>Texto do primeiro par.</p>" },
    { "type": "text", "id": "button_text_1", "label": "Texto do botão" },
    { "type": "url", "id": "button_link_1", "label": "Link do botão" },
    { "type": "video", "id": "video_1", "label": "Vídeo (upload)" },
    { "type": "text", "id": "video_url_1", "label": "URL do vídeo (YouTube ou Vimeo)" },
    { "type": "header", "content": "Par 2 — Conteúdo" },
    { "type": "text", "id": "kicker_2", "label": "Texto superior" },
    { "type": "text", "id": "heading_2", "label": "Título", "default": "Título 2" },
    { "type": "richtext", "id": "text_2", "label": "Texto", "default": "<p>Texto do segundo par.</p>" },
    { "type": "text", "id": "button_text_2", "label": "Texto do botão" },
    { "type": "url", "id": "button_link_2", "label": "Link do botão" },
    { "type": "video", "id": "video_2", "label": "Vídeo (upload)" },
    { "type": "text", "id": "video_url_2", "label": "URL do vídeo (YouTube ou Vimeo)" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "container_width", "label": "Largura do container", "min": 800, "max": 1600, "step": 50, "unit": "px", "default": 1200 },
    { "type": "range", "id": "section_padding", "label": "Espaçamento vertical", "min": 0, "max": 100, "step": 5, "unit": "px", "default": 60 },
    { "type": "range", "id": "horizontal_padding", "label": "Espaçamento horizontal", "min": 0, "max": 100, "step": 5, "unit": "px", "default": 30 },
    { "type": "range", "id": "gap", "label": "Espaço entre colunas e rows", "min": 20, "max": 100, "step": 5, "unit": "px", "default": 60 },
    { "type": "range", "id": "content_gap", "label": "Espaço entre elementos de texto", "min": 10, "max": 50, "step": 5, "unit": "px", "default": 20 },
    { "type": "color", "id": "background_color", "label": "Cor de fundo", "default": "#ffffff" },
    { "type": "header", "content": "Vídeo" },
    {
      "type": "select", "id": "aspect_ratio", "label": "Proporção do vídeo",
      "options": [
        { "value": "16/9", "label": "16:9 (Horizontal)" },
        { "value": "1/1", "label": "1:1 (Quadrado)" },
        { "value": "3/4", "label": "3:4 (Vertical)" },
        { "value": "9/16", "label": "9:16 (Vertical)" }
      ],
      "default": "9/16"
    },
    { "type": "range", "id": "video_width", "label": "Largura do vídeo", "min": 50, "max": 100, "step": 1, "unit": "%", "default": 100 },
    { "type": "range", "id": "media_radius", "label": "Raio da borda", "min": 0, "max": 40, "step": 5, "unit": "px", "default": 10 },
    { "type": "checkbox", "id": "auto_play", "label": "Reprodução automática", "default": false },
    { "type": "checkbox", "id": "loop", "label": "Loop", "default": true },
    { "type": "checkbox", "id": "mute_video", "label": "Sem som", "default": false },
    { "type": "checkbox", "id": "show_controls", "label": "Mostrar controles", "default": true },
    { "type": "header", "content": "Estilo do texto" },
    { "type": "range", "id": "kicker_size", "label": "Tamanho do texto superior", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 12 },
    { "type": "color", "id": "kicker_color", "label": "Cor do texto superior", "default": "#006652" },
    { "type": "range", "id": "heading_size", "label": "Tamanho do título", "min": 20, "max": 80, "step": 2, "unit": "px", "default": 40 },
    { "type": "color", "id": "heading_color", "label": "Cor do título", "default": "#0a0a0c" },
    { "type": "range", "id": "text_size", "label": "Tamanho do texto", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 16 },
    { "type": "color", "id": "text_color", "label": "Cor do texto", "default": "#3c3f36" },
    { "type": "header", "content": "Botão" },
    { "type": "range", "id": "button_text_size", "label": "Tamanho do texto", "min": 12, "max": 24, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "button_padding_vertical", "label": "Espaçamento vertical", "min": 8, "max": 30, "step": 2, "unit": "px", "default": 14 },
    { "type": "range", "id": "button_padding_horizontal", "label": "Espaçamento horizontal", "min": 16, "max": 60, "step": 4, "unit": "px", "default": 32 },
    { "type": "range", "id": "button_radius", "label": "Raio da borda", "min": 0, "max": 50, "step": 5, "unit": "px", "default": 5 },
    { "type": "color", "id": "button_bg_color", "label": "Cor de fundo", "default": "#006652" },
    { "type": "color", "id": "button_text_color", "label": "Cor do texto", "default": "#ffffff" },
    { "type": "color", "id": "button_hover_bg_color", "label": "Cor de fundo (hover)", "default": "#3c3f36" },
    { "type": "color", "id": "button_hover_text_color", "label": "Cor do texto (hover)", "default": "#ffffff" },
    { "type": "header", "content": "Mobile" },
    { "type": "checkbox", "id": "mobile_video_first", "label": "Vídeo primeiro no mobile", "default": true },
    { "type": "range", "id": "mobile_gap", "label": "Espaço entre elementos", "min": 20, "max": 60, "step": 5, "unit": "px", "default": 30 }
  ],
  "presets": [
    { "name": "Par de vídeo e texto" }
  ]
}
{% endschema %}