{% doc %}
  @prompt
    text with slider with 3 images in the left side
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-image-slider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-text-image-slider__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    align-items: center;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-text-image-slider__images-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-text-image-slider__slider-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
  }

  .ai-text-image-slider__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
  }

  .ai-text-image-slider__slide-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-text-image-slider__slide-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-text-image-slider__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-text-image-slider__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-text-image-slider__controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 2;
  }

  .ai-text-image-slider__dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-text-image-slider__dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-text-image-slider__arrows-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 0 10px;
    pointer-events: none;
    z-index: 2;
  }

  .ai-text-image-slider__arrow-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: {{ block.settings.arrow_bg_color }};
    color: {{ block.settings.arrow_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: auto;
    transition: background-color 0.3s ease;
  }

  .ai-text-image-slider__arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_bg_color }};
  }

  .ai-text-image-slider__arrow-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-text-image-slider__content-{{ ai_gen_id }} {
    flex: 1;
    color: {{ block.settings.text_color }};
  }

  .ai-text-image-slider__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    color: {{ block.settings.heading_color }};
  }

  .ai-text-image-slider__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  .ai-text-image-slider__button-{{ ai_gen_id }} {
    display: inline-block;
    margin-top: {{ block.settings.button_spacing }}px;
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: background-color 0.3s ease;
  }

  .ai-text-image-slider__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-text-image-slider__container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-text-image-slider__images-{{ ai_gen_id }} {
      flex: 0 0 auto;
      width: 100%;
    }

    .ai-text-image-slider__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-text-image-slider__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }
  }
{% endstyle %}

<text-image-slider-{{ ai_gen_id }} class="ai-text-image-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-image-slider__container-{{ ai_gen_id }}">
    <div class="ai-text-image-slider__images-{{ ai_gen_id }}">
      <div class="ai-text-image-slider__slider-{{ ai_gen_id }}">
        {% if block.settings.image_1 or block.settings.image_2 or block.settings.image_3 %}
          {% if block.settings.image_1 %}
            <div class="ai-text-image-slider__slide-{{ ai_gen_id }} active" data-slide="0">
              <img
                src="{{ block.settings.image_1 | image_url: width: 1000 }}"
                alt="{{ block.settings.image_1.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.image_1.width }}"
                height="{{ block.settings.image_1.height }}"
              >
            </div>
          {% endif %}

          {% if block.settings.image_2 %}
            <div class="ai-text-image-slider__slide-{{ ai_gen_id }}" data-slide="1">
              <img
                src="{{ block.settings.image_2 | image_url: width: 1000 }}"
                alt="{{ block.settings.image_2.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.image_2.width }}"
                height="{{ block.settings.image_2.height }}"
              >
            </div>
          {% endif %}

          {% if block.settings.image_3 %}
            <div class="ai-text-image-slider__slide-{{ ai_gen_id }}" data-slide="2">
              <img
                src="{{ block.settings.image_3 | image_url: width: 1000 }}"
                alt="{{ block.settings.image_3.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.image_3.width }}"
                height="{{ block.settings.image_3.height }}"
              >
            </div>
          {% endif %}

          {% if block.settings.show_arrows %}
            <div class="ai-text-image-slider__arrows-{{ ai_gen_id }}">
              <button class="ai-text-image-slider__arrow-{{ ai_gen_id }} ai-text-image-slider__arrow-prev-{{ ai_gen_id }}" aria-label="Previous image">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
              </button>
              <button class="ai-text-image-slider__arrow-{{ ai_gen_id }} ai-text-image-slider__arrow-next-{{ ai_gen_id }}" aria-label="Next image">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </button>
            </div>
          {% endif %}

          {% if block.settings.show_dots %}
            <div class="ai-text-image-slider__controls-{{ ai_gen_id }}">
              {% if block.settings.image_1 %}
                <button class="ai-text-image-slider__dot-{{ ai_gen_id }} active" data-slide="0" aria-label="Go to image 1"></button>
              {% endif %}
              {% if block.settings.image_2 %}
                <button class="ai-text-image-slider__dot-{{ ai_gen_id }}" data-slide="1" aria-label="Go to image 2"></button>
              {% endif %}
              {% if block.settings.image_3 %}
                <button class="ai-text-image-slider__dot-{{ ai_gen_id }}" data-slide="2" aria-label="Go to image 3"></button>
              {% endif %}
            </div>
          {% endif %}
        {% else %}
          <div class="ai-text-image-slider__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-text-image-slider__content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-text-image-slider__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-text-image-slider__text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-text-image-slider__button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</text-image-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class TextImageSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = this.querySelectorAll('.ai-text-image-slider__slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-text-image-slider__dot-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-text-image-slider__arrow-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-text-image-slider__arrow-next-{{ ai_gen_id }}');

        if (this.slides.length === 0) return;

        this.setupEventListeners();
        
        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      setupEventListeners() {
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            this.goToSlide(index);
            this.resetAutoplay();
          });
        });

        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.previousSlide();
            this.resetAutoplay();
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.nextSlide();
            this.resetAutoplay();
          });
        }
      }

      goToSlide(index) {
        this.slides.forEach((slide, i) => {
          if (i === index) {
            slide.classList.add('active');
          } else {
            slide.classList.remove('active');
          }
        });

        this.dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });

        this.currentSlide = index;
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      resetAutoplay() {
        {% if block.settings.autoplay %}
          if (this.autoplayInterval) {
            clearInterval(this.autoplayInterval);
            this.startAutoplay();
          }
        {% endif %}
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('text-image-slider-{{ ai_gen_id }}', TextImageSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
