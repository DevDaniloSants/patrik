{% doc %}
  @prompt
    preciso criar uma section exatamente igual ao text with image, que eu possa diminuir e aumentar o titulo e o texto e que o texto possa vir antes da imagem no mobile, a imagem precisa ficar na horizontal, tamanho menor. preciso conseguir ajustar isso. preciso conseguir centralizar o texto também, na imagem precisa ter um botón exatamente com as mesmo configurações da section image navigator dessa página. preciso conseguir alterar essas configurações, você botou todas as configurações mas o botón não apareceu na imagem, o titulo e o texto precisam ficar sempre centralizados horizontalmente com a imagem, errou. o titulo e texto precisa ficar na mesma linha que a imagem no desk, sempre centralizados
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-image-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-text-image-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {% if block.settings.image_position_desktop == 'right' %}row-reverse{% else %}row{% endif %};
    align-items: center;
    justify-content: center;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-text-image-content-{{ ai_gen_id }} {
    flex: 1;
    text-align: {{ block.settings.text_alignment }};
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: {{ block.settings.content_padding_top }}px;
    padding-bottom: {{ block.settings.content_padding_bottom }}px;
    box-sizing: border-box;
  }

  .ai-text-image-media-{{ ai_gen_id }} {
    width: {{ block.settings.image_width }}%;
    flex-shrink: 0;
    position: relative;
  }

  .ai-text-image-media-{{ ai_gen_id }} img {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    object-fit: cover;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-text-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-text-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-text-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-text-image-button-{{ ai_gen_id }} {
    position: absolute;
    {% if block.settings.button_position_vertical == 'top' %}
      top: {{ block.settings.button_offset_vertical }}px;
    {% elsif block.settings.button_position_vertical == 'center' %}
      top: 50%;
    {% else %}
      bottom: {{ block.settings.button_offset_vertical }}px;
    {% endif %}
    {% if block.settings.button_position_horizontal == 'left' %}
      left: {{ block.settings.button_offset_horizontal }}px;
    {% elsif block.settings.button_position_horizontal == 'center' %}
      left: 50%;
    {% else %}
      right: {{ block.settings.button_offset_horizontal }}px;
    {% endif %}
    {% if block.settings.button_position_vertical == 'center' and block.settings.button_position_horizontal == 'center' %}
      transform: translate(-50%, -50%);
    {% elsif block.settings.button_position_vertical == 'center' %}
      transform: translateY(-50%);
    {% elsif block.settings.button_position_horizontal == 'center' %}
      transform: translateX(-50%);
    {% endif %}
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    text-transform: {% if block.settings.button_uppercase %}uppercase{% else %}none{% endif %};
    letter-spacing: {% if block.settings.button_uppercase %}0.05em{% else %}normal{% endif %};
    opacity: {{ block.settings.button_opacity | divided_by: 100.0 }};
    z-index: 2;
  }

  .ai-text-image-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_color_hover }};
    color: {{ block.settings.button_text_color_hover }};
    border-color: {{ block.settings.button_border_color_hover }};
  }

  .ai-text-image-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    line-height: 1.2;
  }

  .ai-text-image-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-text-image-text-{{ ai_gen_id }} p {
    margin: 0 0 1em;
  }

  .ai-text-image-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-text-image-container-{{ ai_gen_id }} {
      gap: {{ block.settings.spacing_mobile }}px;
      flex-direction: {% if block.settings.mobile_text_first %}column{% else %}column-reverse{% endif %};
    }

    .ai-text-image-content-{{ ai_gen_id }} {
      text-align: {{ block.settings.text_alignment_mobile }};
      padding-top: 0;
      padding-bottom: 0;
    }

    .ai-text-image-media-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-text-image-media-{{ ai_gen_id }} img {
      height: {{ block.settings.image_height_mobile }}px;
    }

    .ai-text-image-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.image_height_mobile }}px;
    }

    .ai-text-image-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-text-image-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-text-image-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size_mobile }}px;
      padding: {{ block.settings.button_padding_vertical_mobile }}px {{ block.settings.button_padding_horizontal_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-text-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-image-container-{{ ai_gen_id }}">
    <div class="ai-text-image-content-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-text-image-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.text != blank %}
        <div class="ai-text-image-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}
    </div>

    <div class="ai-text-image-media-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
        >
      {% else %}
        <div class="ai-text-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-text-image-empty-state-{{ ai_gen_id }}">
            Adicione uma imagem
          </div>
        </div>
      {% endif %}
      {% if block.settings.button_text != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-text-image-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Texto com imagem",
  "settings": [
    {
      "type": "header",
      "content": "Conteúdo"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Título",
      "default": "Texto com imagem"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texto",
      "default": "<p>Combine texto e imagens para criar uma seção impactante e informativa.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagem"
    },
    {
      "type": "header",
      "content": "Posição do conteúdo (desktop)"
    },
    {
      "type": "select",
      "id": "image_position_desktop",
      "label": "Posição da imagem no desktop",
      "options": [
        { "value": "left", "label": "Esquerda" },
        { "value": "right", "label": "Direita" }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "content_padding_top",
      "label": "Distância do título ao topo",
      "min": 0,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "content_padding_bottom",
      "label": "Distância do texto à base",
      "min": 0,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Botão na imagem"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto do botón",
      "default": "Saiba mais"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link do botón"
    },
    {
      "type": "range",
      "id": "button_opacity",
      "label": "Opacidade do botón",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "button_position_vertical",
      "label": "Posição vertical",
      "options": [
        { "value": "top", "label": "Topo" },
        { "value": "center", "label": "Centro" },
        { "value": "bottom", "label": "Inferior" }
      ],
      "default": "bottom"
    },
    {
      "type": "select",
      "id": "button_position_horizontal",
      "label": "Posição horizontal",
      "options": [
        { "value": "left", "label": "Esquerda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Direita" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "button_offset_vertical",
      "label": "Distância vertical",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "button_offset_horizontal",
      "label": "Distância horizontal",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Estilo do botón"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Tamanho da fonte desktop",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_font_size_mobile",
      "label": "Tamanho da fonte mobile",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "button_font_weight",
      "label": "Peso da fonte",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Médio" },
        { "value": "600", "label": "Semi-negrito" },
        { "value": "700", "label": "Negrito" }
      ],
      "default": "600"
    },
    {
      "type": "checkbox",
      "id": "button_uppercase",
      "label": "Texto em maiúsculas",
      "default": false
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Padding vertical desktop",
      "min": 5,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Padding horizontal desktop",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "button_padding_vertical_mobile",
      "label": "Padding vertical mobile",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "button_padding_horizontal_mobile",
      "label": "Padding horizontal mobile",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
