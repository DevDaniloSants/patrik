      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Cores do botón"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Fundo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Texto",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Borda",
      "default": "#000000"
    },
    {
      "type": "color",
