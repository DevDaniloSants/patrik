{% doc %}
  @prompt
    Modify the existing clickable banner block to have 11 clickable areas (hotspots). Each area should be independently configurable with its own link URL, position (top % and left %), and size (width % and height %) settings, allowing merchants to define hotspot regions on the banner image that redirect to different URLs when clicked. The banner should display a background image with invisible clickable overlay zones.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-clickable-banner-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-clickable-banner__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-clickable-banner__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-clickable-banner__placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-clickable-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-clickable-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-clickable-banner__hotspot-{{ ai_gen_id }} {
    position: absolute;
    cursor: pointer;
    z-index: 2;
    transition: background-color 0.2s ease;
  }

  .ai-clickable-banner__hotspot-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.hotspot_hover_color }};
  }

  .ai-clickable-banner__hotspot-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.hotspot_focus_color }};
    outline-offset: 2px;
  }

  @media screen and (max-width: 749px) {
    .ai-clickable-banner-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<clickable-banner-{{ ai_gen_id }}
  class="ai-clickable-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-clickable-banner__wrapper-{{ ai_gen_id }}">
    {% if block.settings.banner_image %}
      <img
        src="{{ block.settings.banner_image | image_url: width: 2000 }}"
        alt="{{ block.settings.banner_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.banner_image.width }}"
        height="{{ block.settings.banner_image.height }}"
        class="ai-clickable-banner__image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-clickable-banner__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-clickable-banner__empty-state-{{ ai_gen_id }}">
          Add a banner image to get started
        </div>
      </div>
    {% endif %}

    {% for i in (1..11) %}
      {% liquid
        assign hotspot_enabled_key = 'hotspot_' | append: i | append: '_enabled'
        assign hotspot_url_key = 'hotspot_' | append: i | append: '_url'
        assign hotspot_top_key = 'hotspot_' | append: i | append: '_top'
        assign hotspot_left_key = 'hotspot_' | append: i | append: '_left'
        assign hotspot_width_key = 'hotspot_' | append: i | append: '_width'
        assign hotspot_height_key = 'hotspot_' | append: i | append: '_height'

        assign hotspot_enabled = block.settings[hotspot_enabled_key]
        assign hotspot_url = block.settings[hotspot_url_key]
        assign hotspot_top = block.settings[hotspot_top_key]
        assign hotspot_left = block.settings[hotspot_left_key]
        assign hotspot_width = block.settings[hotspot_width_key]
        assign hotspot_height = block.settings[hotspot_height_key]
      %}

      {% if hotspot_enabled and hotspot_url != blank %}
        <a
          href="{{ hotspot_url }}"
          class="ai-clickable-banner__hotspot-{{ ai_gen_id }}"
          style="
            top: {{ hotspot_top }}%;
            left: {{ hotspot_left }}%;
            width: {{ hotspot_width }}%;
            height: {{ hotspot_height }}%;
          "
          aria-label="Clickable area {{ i }}"
        ></a>
      {% endif %}
    {% endfor %}
  </div>
</clickable-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class ClickableBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.hotspots = this.querySelectorAll('.ai-clickable-banner__hotspot-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.hotspots.forEach((hotspot) => {
          hotspot.addEventListener('click', function(event) {
            if (!hotspot.href || hotspot.href === '') {
              event.preventDefault();
            }
          });
        });
      }
    }

    customElements.define('clickable-banner-{{ ai_gen_id }}', ClickableBanner{{ ai_gen_id }});
  })();
</script>

