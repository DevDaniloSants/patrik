{% doc %}
  @prompt
    preciso criar um banner slider onde eu possa escrever o texto para cada imagem dentro dela e fique com as setinhas de ir para o lado para que seja facil de entender que é para ir para o lado 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-slider-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-banner-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.slider_height }}px;
  }

  .ai-banner-slider-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
    height: 100%;
  }

  .ai-banner-slide-{{ ai_gen_id }} {
    min-width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
  }

  .ai-banner-slide-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-banner-slide-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-banner-slide-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-banner-slide-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
  }

  .ai-banner-slide-content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    text-align: {{ block.settings.text_alignment }};
    padding: 60px 60px 40px 60px;
    max-width: {{ block.settings.content_max_width }}px;
    color: {{ block.settings.text_color }};
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
  }

  .ai-banner-slide-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 16px;
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-banner-slide-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    margin: 0;
    line-height: 1.6;
    white-space: pre-wrap;
  }

  .ai-banner-slider-arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    opacity: 0.9;
  }

  .ai-banner-slider-arrow-{{ ai_gen_id }}:hover {
    opacity: 1;
    transform: translateY(-50%) scale(1.1);
  }

  .ai-banner-slider-arrow-{{ ai_gen_id }}--prev {
    left: 20px;
  }

  .ai-banner-slider-arrow-{{ ai_gen_id }}--next {
    right: 20px;
  }

  .ai-banner-slider-arrow-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
  }

  .ai-banner-slider-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 10;
  }

  .ai-banner-slider-dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.3s ease;
    padding: 0;
  }

  .ai-banner-slider-dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-banner-slider-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.slider_height_mobile }}px;
    }

    .ai-banner-slide-content-{{ ai_gen_id }} {
      padding: 30px 20px 20px 20px;
    }

    .ai-banner-slide-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-banner-slide-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.85 }}px;
    }

    .ai-banner-slider-arrow-{{ ai_gen_id }} {
      width: {{ block.settings.arrow_size | times: 0.8 }}px;
      height: {{ block.settings.arrow_size | times: 0.8 }}px;
    }

    .ai-banner-slider-arrow-{{ ai_gen_id }}--prev {
      left: 10px;
    }

    .ai-banner-slider-arrow-{{ ai_gen_id }}--next {
      right: 10px;
    }
  }
{% endstyle %}

<banner-slider-{{ ai_gen_id }}
  class="ai-banner-slider-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-banner-slider-wrapper-{{ ai_gen_id }}">
    <div class="ai-banner-slider-track-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          assign slide_image_key = 'slide_' | append: i | append: '_image'
          assign slide_title_key = 'slide_' | append: i | append: '_title'
          assign slide_text_key = 'slide_' | append: i | append: '_text'

          assign slide_enabled = block.settings[slide_enabled_key]
          assign slide_image = block.settings[slide_image_key]
          assign slide_title = block.settings[slide_title_key]
          assign slide_text = block.settings[slide_text_key]
        %}

        {% if slide_enabled %}
          <div class="ai-banner-slide-{{ ai_gen_id }}" data-slide="{{ forloop.index0 }}">
            {% if slide_image %}
              <img
                src="{{ slide_image | image_url: width: 2000 }}"
                alt="{{ slide_image.alt | escape }}"
                loading="lazy"
                width="{{ slide_image.width }}"
                height="{{ slide_image.height }}"
                class="ai-banner-slide-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-banner-slide-placeholder-{{ ai_gen_id }}">
                {{ 'hero-apparel-1' | placeholder_svg_tag }}
              </div>
            {% endif %}

            {% if block.settings.show_overlay %}
              <div class="ai-banner-slide-overlay-{{ ai_gen_id }}"></div>
            {% endif %}

            <div class="ai-banner-slide-content-{{ ai_gen_id }}">
              {% if slide_title != blank %}
                <h2 class="ai-banner-slide-title-{{ ai_gen_id }}">{{ slide_title }}</h2>
              {% endif %}
              {% if slide_text != blank %}
                <p class="ai-banner-slide-text-{{ ai_gen_id }}">{{ slide_text }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_arrows %}
      <button
        class="ai-banner-slider-arrow-{{ ai_gen_id }} ai-banner-slider-arrow-{{ ai_gen_id }}--prev"
        aria-label="Slide anterior"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button
        class="ai-banner-slider-arrow-{{ ai_gen_id }} ai-banner-slider-arrow-{{ ai_gen_id }}--next"
        aria-label="Próximo slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-banner-slider-dots-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</banner-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class BannerSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-banner-slider-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-banner-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-banner-slider-arrow-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-banner-slider-arrow-{{ ai_gen_id }}--next');
        this.dotsContainer = this.querySelector('.ai-banner-slider-dots-{{ ai_gen_id }}');

        if (this.slides.length === 0) return;

        this.createDots();
        this.setupEventListeners();
        this.updateSlider();

        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      createDots() {
        if (!this.dotsContainer) return;

        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-banner-slider-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', 'Ir para slide ' + (index + 1));
          if (index === 0) dot.classList.add('active');
          dot.addEventListener('click', () => this.goToSlide(index));
          this.dotsContainer.appendChild(dot);
        });
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.prevSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        let touchStartX = 0;
        let touchEndX = 0;

        this.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        });

        this.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe(touchStartX, touchEndX);
        });
      }

      handleSwipe(startX, endX) {
        const swipeThreshold = 50;
        if (startX - endX > swipeThreshold) {
          this.nextSlide();
        } else if (endX - startX > swipeThreshold) {
          this.prevSlide();
        }
      }

      prevSlide() {
        this.currentSlide = this.currentSlide === 0 ? this.slides.length - 1 : this.currentSlide - 1;
        this.updateSlider();
        this.resetAutoplay();
      }

      nextSlide() {
        this.currentSlide = this.currentSlide === this.slides.length - 1 ? 0 : this.currentSlide + 1;
        this.updateSlider();
        this.resetAutoplay();
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateSlider();
        this.resetAutoplay();
      }

      updateSlider() {
        const offset = -this.currentSlide * 100;
        this.track.style.transform = 'translateX(' + offset + '%)';

        if (this.dotsContainer) {
          const dots = this.dotsContainer.querySelectorAll('.ai-banner-slider-dot-{{ ai_gen_id }}');
          dots.forEach((dot, index) => {
            if (index === this.currentSlide) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });
        }
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      resetAutoplay() {
        {% if block.settings.autoplay %}
          if (this.autoplayInterval) {
            clearInterval(this.autoplayInterval);
            this.startAutoplay();
          }
        {% endif %}
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('banner-slider-{{ ai_gen_id }}', BannerSlider{{ ai_gen_id }});
  })();
</script>

