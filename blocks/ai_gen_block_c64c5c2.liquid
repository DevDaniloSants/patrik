      "label": "Image"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Title",
      "default": "Collection 2"
    },
    {
      "type": "url",
      "id": "link_2",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title_3",
      "label": "Title",
      "default": "Collection 3"
    },
    {
      "type": "url",
      "id": "link_3",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Image 4"
