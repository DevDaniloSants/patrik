{% doc %}
  @prompt
    preciso de uma section igual ao image navigator da página fe-e-protecao, mas conseguindo incluir 4 imagens e titulo principal acima das imagens 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-navigator-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    display: block;
  }

  .ai-image-navigator-container-{{ ai_gen_id }} {
    max-width: {{ settings.layout_site_width }}px;
    margin: 0 auto;
    padding: 0 {{ settings.layout_outer }}px;
  }

  .ai-image-navigator-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.title_alignment }};
    margin-bottom: {{ block.settings.title_spacing }}px;
  }

  .ai-image-navigator-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    font-family: {{ settings.font_heading_family.family }}, {{ settings.font_heading_family.fallback_families }};
    font-weight: {{ settings.font_heading_family.weight }};
    font-style: {{ settings.font_heading_family.style }};
  }

  .ai-image-navigator-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-image-navigator-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-navigator-link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    text-decoration: none;
    width: 100%;
    height: 100%;
  }

  .ai-image-navigator-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
  }

  .ai-image-navigator-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  {% if block.settings.enable_hover_zoom %}
    .ai-image-navigator-link-{{ ai_gen_id }}:hover .ai-image-navigator-image-{{ ai_gen_id }} {
      transform: scale(1.05);
    }
  {% endif %}

  .ai-image-navigator-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.placeholder_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-navigator-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-image-navigator-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: {{ block.settings.overlay_gradient }};
    padding: {{ block.settings.overlay_padding }}px;
    transition: opacity 0.3s ease;
  }

  {% if block.settings.hide_overlay_on_hover %}
    .ai-image-navigator-link-{{ ai_gen_id }}:hover .ai-image-navigator-overlay-{{ ai_gen_id }} {
      opacity: 0;
    }
  {% endif %}

  .ai-image-navigator-item-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_title_size }}px;
    color: {{ block.settings.overlay_text_color }};
    margin: 0;
    font-family: {{ settings.font_heading_family.family }}, {{ settings.font_heading_family.fallback_families }};
    font-weight: {{ settings.font_heading_family.weight }};
    text-align: {{ block.settings.overlay_text_alignment }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-navigator-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-image-navigator-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-image-navigator-item-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.item_title_size }}px * 0.85);
    }
  }
{% endstyle %}

<div class="ai-image-navigator-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-navigator-container-{{ ai_gen_id }}">
    {% if block.settings.main_title != blank %}
      <div class="ai-image-navigator-header-{{ ai_gen_id }}">
        <h2 class="ai-image-navigator-title-{{ ai_gen_id }}">{{ block.settings.main_title }}</h2>
      </div>
    {% endif %}

    <div class="ai-image-navigator-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign title_key = 'title_' | append: i
          assign link_key = 'link_' | append: i
          
          assign image = block.settings[image_key]
          assign title = block.settings[title_key]
          assign link = block.settings[link_key]
        %}

        <div class="ai-image-navigator-item-{{ ai_gen_id }}">
          {% if link != blank %}
            <a href="{{ link }}" class="ai-image-navigator-link-{{ ai_gen_id }}">
          {% else %}
            <div class="ai-image-navigator-link-{{ ai_gen_id }}">
          {% endif %}
            
            <div class="ai-image-navigator-image-wrapper-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 800 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  class="ai-image-navigator-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-image-navigator-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            {% if title != blank %}
              <div class="ai-image-navigator-overlay-{{ ai_gen_id }}">
                <h3 class="ai-image-navigator-item-title-{{ ai_gen_id }}">{{ title }}</h3>
              </div>
            {% endif %}

          {% if link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image navigator",
  "settings": [
    {
      "type": "header",
      "content": "Main title"
    },
    {
      "type": "text",
      "id": "main_title",
      "label": "Title",
      "default": "Explore our collections"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#3c3f36"
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Title alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Space below title",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Space between images",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Image style"
    },
    {
      "type": "range",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "min": 0.5,
      "max": 2,
      "step": 0.1,
      "unit": ":1",
      "default": 1
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "enable_hover_zoom",
      "label": "Enable hover zoom",
      "default": true
    },
    {
      "type": "color",
      "id": "placeholder_bg_color",
      "label": "Placeholder background",
      "default": "#f7f5f4"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "range",
      "id": "item_title_size",
      "label": "Title size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "overlay_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "overlay_text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "overlay_gradient",
      "label": "Overlay gradient",
      "default": "linear-gradient(to top, rgba(0,0,0,0.6), transparent)",
      "info": "CSS gradient value"
    },
    {
      "type": "range",
      "id": "overlay_padding",
      "label": "Overlay padding",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "hide_overlay_on_hover",
      "label": "Hide overlay on hover",
      "default": false
    },
    {
      "type": "header",
      "content": "Image 1"
    },
    {
      "type": "image_picker",
