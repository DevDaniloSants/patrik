<style>
  .pj-cats{padding:{{ section.settings.pad_topo }}px 24px {{ section.settings.pad_base }}px;background:{{ section.settings.fundo }}}
  .pj-cats-inner{max-width:none;margin:0 auto;position:relative}
  .pj-cats-titulo{text-align:center;font-size:22px;letter-spacing:.12em;text-transform:uppercase;margin:0 0 8px;color:#1e1e1e}
  .pj-cats-sub{text-align:center;font-size:13.5px;color:#6f6f6f;margin:0 0 34px}
  {%- assign gap_total = section.settings.colunas | times: 16 -%}
  .pj-cats-grid{display:flex;gap:16px;overflow-x:auto;scroll-snap-type:x mandatory;scrollbar-width:none;padding-bottom:6px}
  .pj-cats-grid::-webkit-scrollbar{display:none}
  .pj-cat{display:block;text-align:left;text-decoration:none;flex:0 0 calc((100% - {{ gap_total }}px - 48px)/{{ section.settings.colunas }});scroll-snap-align:start}
  .pj-cats-seta{position:absolute;top:42%;transform:translateY(-50%);width:42px;height:42px;border-radius:50%;background:#fff;border:1px solid #e6e6e6;box-shadow:0 2px 10px rgba(0,0,0,.10);display:flex;align-items:center;justify-content:center;cursor:pointer;z-index:2;font-size:18px;color:#1e1e1e;line-height:1;padding:0}
  .pj-cats-seta:hover{background:#f6f6f6}
  .pj-seta-esq{left:4px}
  .pj-seta-dir{right:4px}
  .pj-cat-img{aspect-ratio:{{ section.settings.formato }};border-radius:4px;overflow:hidden;background:#f1f1ef}
  .pj-cat-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
  .pj-cat:hover .pj-cat-img img{transform:scale(1.05)}
  .pj-cat-nome{display:block;margin-top:14px;font-size:12.5px;letter-spacing:.1em;text-transform:uppercase;color:#1e1e1e;transition:.25s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;text-align:left}
  .pj-cat:hover .pj-cat-nome{color:#b39055}
  @media(max-width:1024px){
    .pj-cats-grid{padding:8px 15% 4px;gap:12px}
    .pj-cat{flex:0 0 calc(100%/{{ section.settings.mobile_visiveis | default: '1.4' }} - 12px);scroll-snap-align:center;transform:scale(.86);transform-origin:center;transition:transform .35s ease}
    .pj-cat.pj-ativo{transform:scale(1)}
    .pj-cat .pj-cat-nome{opacity:.35;transition:opacity .3s}
    .pj-cat.pj-ativo .pj-cat-nome{opacity:1}
    .pj-cats-titulo{font-size:18px}
    .pj-cats{padding-left:8px;padding-right:8px}
    .pj-cats-seta{display:flex;width:36px;height:36px}
  }
</style>
 
<section class="pj-cats">
  <div class="pj-cats-inner">
    {%- if section.settings.titulo != blank -%}
      <h2 class="pj-cats-titulo">{{ section.settings.titulo }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitulo != blank -%}
      <p class="pj-cats-sub">{{ section.settings.subtitulo }}</p>
    {%- endif -%}
    <button class="pj-cats-seta pj-seta-esq" type="button" aria-label="Anterior" data-pj-dir="-1">&#8249;</button>
    <button class="pj-cats-seta pj-seta-dir" type="button" aria-label="Próximo" data-pj-dir="1">&#8250;</button>
    <div class="pj-cats-grid" id="pj-cats-{{ section.id }}">
      {%- for block in section.blocks -%}
        <a class="pj-cat" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          <div class="pj-cat-img">
            {%- if block.settings.imagem -%}
              <img src="{{ block.settings.imagem | image_url: width: 600 }}" alt="{{ block.settings.nome | escape }}" loading="lazy">
            {%- endif -%}
          </div>
          {%- if block.settings.nome != blank -%}
            <span class="pj-cat-nome">{{ block.settings.nome }}</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
 
<script>
(function(){
  var grid = document.getElementById('pj-cats-{{ section.id }}');
  if (!grid) return;
  var setas = grid.parentElement.querySelectorAll('.pj-cats-seta');
  setas.forEach(function(btn){
    btn.addEventListener('click', function(){
      var card = grid.querySelector('.pj-cat');
      if (!card) return;
      var passo = (card.offsetWidth + 16) * parseInt(btn.dataset.pjDir);
      grid.scrollBy({left: passo, behavior: 'smooth'});
    });
  });
 
  /* cartão central em destaque (estilo carrossel) */
  function pjMarcaAtivo(){
    var meio = grid.scrollLeft + grid.clientWidth / 2;
    var melhor = null, dist = 1e9;
    grid.querySelectorAll('.pj-cat').forEach(function(c){
      var cm = c.offsetLeft + c.offsetWidth / 2;
      var d = Math.abs(cm - meio);
      if (d < dist) { dist = d; melhor = c; }
    });
    grid.querySelectorAll('.pj-cat').forEach(function(c){
      c.classList.toggle('pj-ativo', c === melhor);
    });
  }
  var pjRaf;
  grid.addEventListener('scroll', function(){
    cancelAnimationFrame(pjRaf);
    pjRaf = requestAnimationFrame(pjMarcaAtivo);
  }, {passive:true});
  window.addEventListener('resize', pjMarcaAtivo);
  pjMarcaAtivo();
})();
</script>
 
{% schema %}
{
  "name": "Grade de categorias",
  "settings": [
    {
      "type": "text",
      "id": "titulo",
      "label": "Título (vazio = não mostrar)"
    },
    {
      "type": "text",
      "id": "subtitulo",
      "label": "Subtítulo (vazio = não mostrar)"
    },
    {
      "type": "range",
      "id": "colunas",
      "label": "Cartões visíveis no desktop (o resto desliza)",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "formato",
      "label": "Formato das imagens",
      "options": [
        { "value": "1/1", "label": "Quadrado" },
        { "value": "6/7", "label": "Quase quadrado (referência)" },
        { "value": "4/5", "label": "Retrato" },
        { "value": "3/4", "label": "Retrato alongado" }
      ],
      "default": "6/7"
    },
    {
      "type": "select",
      "id": "mobile_visiveis",
      "label": "Tamanho dos cartões no celular",
      "options": [
        { "value": "1.2", "label": "Grande (1 cartão + espiada)" },
        { "value": "1.6", "label": "Médio (1 e meio)" },
        { "value": "2.2", "label": "Pequeno (2 + espiada)" }
      ],
      "default": "1.6"
    },
    {
      "type": "color",
      "id": "fundo",
      "label": "Cor de fundo",
      "default": "#faf7f2"
    },
    {
      "type": "range",
      "id": "pad_topo",
      "label": "Espaço acima",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_base",
      "label": "Espaço abaixo",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "categoria",
      "name": "Categoria",
      "settings": [
        {
          "type": "image_picker",
          "id": "imagem",
          "label": "Imagem"
        },
        {
          "type": "text",
          "id": "nome",
          "label": "Nome da categoria"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (coleção ou página)"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Grade de categorias",
      "blocks": [
        { "type": "categoria" },
        { "type": "categoria" },
        { "type": "categoria" },
        { "type": "categoria" },
        { "type": "categoria" },
        { "type": "categoria" },
        { "type": "categoria" },
        { "type": "categoria" }
      ]
    }
  ]
}
{% endschema %}