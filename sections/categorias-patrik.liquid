
<style>
  .pj-cats{padding:{{ section.settings.pad_topo }}px 24px {{ section.settings.pad_base }}px;background:{{ section.settings.fundo }}}
  .pj-cats-inner{max-width:1280px;margin:0 auto}
  .pj-cats-titulo{text-align:center;font-size:22px;letter-spacing:.12em;text-transform:uppercase;margin:0 0 8px;color:#1e1e1e}
  .pj-cats-sub{text-align:center;font-size:13.5px;color:#6f6f6f;margin:0 0 34px}
  .pj-cats-grid{display:grid;grid-template-columns:repeat({{ section.settings.colunas }},minmax(0,1fr));gap:10px}
  .pj-cat{display:block;text-align:center;text-decoration:none}
  .pj-cat-img{aspect-ratio:{{ section.settings.formato }};border-radius:4px;overflow:hidden;background:#f1f1ef}
  .pj-cat-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
  .pj-cat:hover .pj-cat-img img{transform:scale(1.05)}
  .pj-cat-nome{display:block;margin-top:10px;font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;color:#1e1e1e;transition:.25s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .pj-cat:hover .pj-cat-nome{color:#b39055}
  /* abaixo do desktop: continua UMA linha, com rolagem lateral */
  @media(max-width:1024px){
    .pj-cats-grid{display:flex;overflow-x:auto;scrollbar-width:none;gap:10px;padding-bottom:4px}
    .pj-cats-grid::-webkit-scrollbar{display:none}
    .pj-cat{flex:0 0 132px}
    .pj-cats-titulo{font-size:18px}
    .pj-cats{padding-left:16px;padding-right:16px}
  }
</style>
 
<section class="pj-cats">
  <div class="pj-cats-inner">
    {%- if section.settings.titulo != blank -%}
      <h2 class="pj-cats-titulo">{{ section.settings.titulo }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitulo != blank -%}
      <p class="pj-cats-sub">{{ section.settings.subtitulo }}</p>
    {%- endif -%}
    <div class="pj-cats-grid">
      {%- for block in section.blocks -%}
        <a class="pj-cat" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          <div class="pj-cat-img">
            {%- if block.settings.imagem -%}
              <img src="{{ block.settings.imagem | image_url: width: 600 }}" alt="{{ block.settings.nome | escape }}" loading="lazy">
            {%- endif -%}
          </div>
          {%- if block.settings.nome != blank -%}
            <span class="pj-cat-nome">{{ block.settings.nome }}</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
 
{% schema %}
{
  "name": "Grade de categorias",
  "settings": [
    {
      "type": "text",
      "id": "titulo",
      "label": "Título (vazio = não mostrar)"
    },
    {
      "type": "text",
      "id": "subtitulo",
      "label": "Subtítulo (vazio = não mostrar)"
    },
    {
      "type": "range",
      "id": "colunas",
      "label": "Colunas no desktop",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 8
    },
    {
      "type": "select",
      "id": "formato",
      "label": "Formato das imagens",
      "options": [
        { "value": "1/1", "label": "Quadrado" },
        { "value": "4/5", "label": "Retrato" },
        { "value": "3/4", "label": "Retrato alongado" },
        { "value": "2/3", "label": "Retrato extra alongado" }
      ],
      "default": "3/4"
    },
    {
      "type": "color",
      "id": "fundo",
      "label": "Cor de fundo",
      "default": "#faf7f2"
    },
    {
      "type": "range",
      "id": "pad_topo",
      "label": "Espaço acima",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "pad_base",
      "label": "Espaço abaixo",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "categoria",
      "name": "Categoria",
      "settings": [
        {
          "type": "image_picker",
          "id": "imagem",
          "label": "Imagem"
        },
        {
          "type": "text",
          "id": "nome",
          "label": "Nome da categoria"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (coleção ou página)"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Grade de categorias",
      "blocks": [
        { "type": "categoria" },
        { "type": "categoria" },
        { "type": "categoria" },
        { "type": "categoria" },
        { "type": "categoria" },
        { "type": "categoria" },
        { "type": "categoria" },
        { "type": "categoria" }
      ]
    }
  ]
}
{% endschema %}