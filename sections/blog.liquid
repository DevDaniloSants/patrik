{% comment %} Testimonials Slider {% endcomment %}
<style>
  .testimonials-slider-section {
    padding: 40px 20px;
    background: {{ section.settings.background_color }};
  }
  .testimonials-slider-section h2 {
    text-align: center;
    font-size: 1.2rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 32px;
    color: {{ section.settings.text_color }};
  }
  .testimonials-wrapper {
    position: relative;
    overflow: hidden;
  }
  .testimonials-track {
    display: flex;
    transition: transform 0.4s ease;
    gap: 24px;
  }
  .testimonial-card {
    flex: 0 0 calc((100% - 48px) / 3);
    border: 1px solid #e8e0d8;
    padding: 28px 24px;
    text-align: center;
    background: #fff;
  }
  .testimonial-card .quote {
    font-size: 0.95rem;
    line-height: 1.7;
    color: {{ section.settings.text_color }};
    margin-bottom: 16px;
    font-style: italic;
  }
  .testimonial-card .author {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999;
  }
  .testimonials-nav {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-top: 24px;
  }
  .testimonials-nav button {
    background: none;
    border: 1px solid #ccc;
    width: 40px;
    height: 40px;
    cursor: pointer;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s;
  }
  .testimonials-nav button:hover {
    border-color: #333;
  }
  @media (max-width: 768px) {
    .testimonial-card { flex: 0 0 calc(100% - 40px); }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .testimonial-card { flex: 0 0 calc((100% - 24px) / 2); }
  }
</style>

<section class="testimonials-slider-section">
  {% if section.settings.title != blank %}
    <h2>{{ section.settings.title }}</h2>
  {% endif %}

  <div class="testimonials-wrapper">
    <div class="testimonials-track" id="testimonialsTrack-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <p class="quote">"{{ block.settings.quote }}"</p>
          <p class="author">— {{ block.settings.author }}</p>
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="testimonials-nav">
    <button onclick="moveSlider('{{ section.id }}', -1)" aria-label="Anterior">&#8592;</button>
    <button onclick="moveSlider('{{ section.id }}', 1)" aria-label="Próximo">&#8594;</button>
  </div>
</section>

<script>
  (function() {
    var currentIndex = {};
    window.moveSlider = function(id, dir) {
      var track = document.getElementById('testimonialsTrack-' + id);
      var cards = track.querySelectorAll('.testimonial-card');
      var visible = window.innerWidth <= 768 ? 1 : window.innerWidth <= 1024 ? 2 : 3;
      var max = Math.max(0, cards.length - visible);
      currentIndex[id] = currentIndex[id] || 0;
      currentIndex[id] = Math.min(Math.max(currentIndex[id] + dir, 0), max);
      var cardWidth = cards[0].offsetWidth + 24;
      track.style.transform = 'translateX(-' + (currentIndex[id] * cardWidth) + 'px)';
    };
  })();
</script>

{% schema %}
{
  "name": "Testimonials Slider",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "O que nossos clientes dizem"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor de fundo",
      "default": "#faf9f7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#2c2c2c"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Depoimento",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Comentário",
          "default": "Uma joia incrível, superou todas as minhas expectativas."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Nome do cliente",
          "default": "Cliente Patrik Joias"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials Slider",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}