{%- comment -%} Sem font-family: títulos e textos herdam automaticamente as fontes do tema {%- endcomment -%}
<style>
  .pj-page{
    --pj-gold:#b39055; --pj-ink:#1e1e1e; --pj-grey:#6f6f6f;
    --pj-line:#e8e2d8; --pj-soft:#faf7f2;
    color:var(--pj-ink);
    overflow-x:clip;
    /* ocupa a largura total da tela, mesmo se o tema limitar o container */
    width:100vw;
    margin-left:calc(50% - 50vw);
  }
  .pj-line-head,.pj-products,.pj-line-info{min-width:0}
  .pj-page *{margin:0;padding:0;box-sizing:border-box}
  .pj-page a{color:inherit;text-decoration:none}
  .pj-page button{font-family:inherit;cursor:pointer}
  .pj-page img{display:block;max-width:100%}
 
  /* Cabeçalho da categoria */
  .pj-category-head{text-align:center;padding:68px 24px 40px;background:#fff}
  .pj-category-head h1{font-size:30px;letter-spacing:.04em;margin-bottom:42px}
  .pj-category-head>p{max-width:600px;margin:0 auto;color:var(--pj-grey);font-size:13.5px;line-height:1.85}
 
  /* Filtro de modelos (título + imagem pequena embaixo) */
  .pj-lines-filter{position:sticky;top:0;z-index:30;background:#fff;border-bottom:1px solid var(--pj-line);padding:22px 0 20px}
  .pj-lines-filter-inner{max-width:none;margin:0;display:flex;align-items:center;gap:8px;padding:0 16px}
  .pj-chips{display:flex;gap:22px;overflow-x:auto;scrollbar-width:none;padding:2px 6px;margin:0 auto}
  .pj-chips::-webkit-scrollbar{display:none}
  .pj-chip{flex:0 0 auto;display:flex;flex-direction:column;align-items:center;gap:14px;padding:4px 2px}
  .pj-chip .pj-chip-title{font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--pj-ink);border-bottom:1px solid transparent;padding-bottom:2px;transition:.25s;white-space:nowrap;max-width:38vw;overflow:hidden;text-overflow:ellipsis}
  .pj-chip .pj-chip-img{width:{{ section.settings.chip_size | default: 96 | times: 2.8 | round }}px;height:{{ section.settings.chip_size | default: 96 | times: 1.3 | round }}px;border-radius:12px;overflow:hidden;background:#fff;transition:.25s}
  .pj-chip .pj-chip-img img{width:100%;height:100%;object-fit:cover}
  .pj-chip:hover .pj-chip-title,.pj-chip.active .pj-chip-title{color:var(--pj-gold);border-color:var(--pj-gold)}
  .pj-chip-arrow{flex:0 0 auto;width:32px;height:32px;border-radius:50%;border:1px solid var(--pj-line);background:#fff;color:var(--pj-grey);display:none;align-items:center;justify-content:center}
 
  /* Seções: imagem + texto em cima, produtos embaixo */
  .pj-line-section{max-width:none;margin:0;padding:64px 36px 40px;border-bottom:1px solid var(--pj-line)}
  .pj-line-head{display:grid;grid-template-columns:{{ section.settings.img_width | default: 480 }}px 1fr;gap:44px;align-items:center;max-width:1080px;margin:0 auto 44px}
  /* modelos pares: imagem à direita, texto à esquerda */
  .pj-flip .pj-line-head{grid-template-columns:1fr {{ section.settings.img_width | default: 480 }}px}
  .pj-flip .pj-line-img{order:2}
  .pj-line-img{aspect-ratio:1/1;background:var(--pj-soft);border-radius:2px;position:relative}
  .pj-line-img::before{content:"";position:absolute;top:22px;right:-22px;bottom:-22px;left:22px;background:var(--pj-soft);z-index:0}
  .pj-flip .pj-line-img::before{right:22px;left:-22px}
  .pj-line-img img{width:100%;height:100%;object-fit:cover;position:relative;z-index:1;border-radius:2px}
  .pj-line-info{text-align:left}
  .pj-line-info h2{font-size:26px;text-transform:uppercase;letter-spacing:.18em;margin-bottom:0}
  .pj-line-info h2::after{content:"";display:block;width:44px;height:1px;background:var(--pj-gold);margin:18px 0 20px}
  .pj-line-info .pj-desc{color:var(--pj-grey);font-size:13px;line-height:1.85;max-width:430px;margin:0}
 
  /* Grade: 4 no desktop, 2 no mobile */
  .pj-products{display:grid;grid-template-columns:repeat(4,1fr);gap:28px 20px}
  .pj-product{text-align:center;display:block}
  .pj-product .pj-thumb{position:relative;aspect-ratio:4/5;background:var(--pj-soft);border-radius:2px;overflow:hidden;margin-bottom:14px}
  .pj-product .pj-thumb img{width:100%;height:100%;object-fit:cover;transition:transform .5s}
  .pj-product:hover .pj-thumb img{transform:scale(1.05)}
  .pj-product .pj-tag{position:absolute;top:10px;left:10px;background:#fff;font-size:10px;letter-spacing:.14em;text-transform:uppercase;padding:4px 10px;color:var(--pj-grey)}
  .pj-product h3{font-weight:400;font-size:14px;text-transform:uppercase;line-height:1.6;letter-spacing:.06em;min-height:2.8em;margin-bottom:8px}
  .pj-price-row{display:flex;justify-content:center;align-items:flex-start;gap:10px}
  .pj-product .pj-price{font-size:14px;font-weight:600}
  .pj-product .pj-installments{font-size:11.5px;color:var(--pj-grey);margin-top:2px}
  .pj-finish{font-size:11.5px;margin-top:12px;text-align:center}
  .pj-swatches{display:flex;justify-content:center;gap:7px;margin-top:8px}
  .pj-swatch{width:14px;height:14px;border-radius:2px;border:1px solid #fff;box-shadow:0 0 0 1px var(--pj-line)}
  .pj-swatch.amarelo{background:linear-gradient(135deg,#e8c977,#c9a24d)}
  .pj-swatch.branco{background:linear-gradient(135deg,#f2f2f0,#c9c9c4)}
  .pj-swatch.rose{background:linear-gradient(135deg,#eec3ad,#d49678)}
 
  .pj-warn{max-width:1280px;margin:20px auto;padding:14px 18px;border:1px dashed var(--pj-gold);color:var(--pj-grey);font-size:13.5px}
 
  /* Bloco exclusivo Patrik */
  .pj-cta{background:#3c3f36;color:#fff;text-align:center;padding:76px 24px}
  .pj-cta h2{font-size:28px;text-transform:uppercase;letter-spacing:.16em;margin-bottom:16px}
  .pj-cta p{max-width:540px;margin:0 auto 30px;font-size:14.5px;line-height:1.85;color:rgba(255,255,255,.82)}
  .pj-cta-btn{display:inline-block;border:1px solid #fff;background:transparent;padding:14px 36px;font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:#fff;transition:.3s;cursor:pointer}
  .pj-cta-btn:hover{background:#fff;color:#3c3f36}
 
  /* FAQ em duas colunas */
  .pj-faq{max-width:1180px;margin:0 auto;padding:80px 24px;display:grid;grid-template-columns:320px 1fr;gap:56px;align-items:start}
  .pj-faq h2{font-size:30px;text-align:left;letter-spacing:.08em;margin-bottom:14px}
  .pj-faq .pj-sub{text-align:left;color:var(--pj-grey);font-size:14.5px;line-height:1.8;margin-bottom:0}
  .pj-accordion-item{border-bottom:1px solid var(--pj-line)}
  .pj-accordion-item button.pj-q{width:100%;background:none;border:none;text-align:left;display:flex;justify-content:space-between;align-items:center;gap:16px;padding:22px 4px;font-size:16.5px;font-weight:400;color:var(--pj-ink)}
  .pj-accordion-item button.pj-q::after{content:"+";font-size:26px;color:var(--pj-gold);transition:.3s}
  .pj-accordion-item.open button.pj-q::after{transform:rotate(45deg)}
  .pj-accordion-item .pj-a{max-height:0;overflow:hidden;transition:max-height .4s ease}
  .pj-accordion-item .pj-a p{padding:0 4px 24px;color:var(--pj-grey);font-size:14.5px;line-height:1.8}
 
  @media(max-width:1024px){
    .pj-line-head,.pj-flip .pj-line-head{grid-template-columns:1fr;gap:24px}
    .pj-flip .pj-line-img{order:0}
    .pj-line-img{max-width:640px;width:100%;margin:0 auto}
    .pj-line-img::before,.pj-flip .pj-line-img::before{top:14px;right:-10px;bottom:-14px;left:10px}
    .pj-faq{grid-template-columns:1fr;gap:20px}
    .pj-products{grid-template-columns:repeat(3,1fr)}
  }
  @media(max-width:860px){
    .pj-category-head h1{font-size:34px}
    .pj-line-info h2{font-size:30px}
    /* setinhas do filtro: apenas no mobile */
    .pj-chip-arrow{display:flex}
    .pj-chips{margin:0}
    .pj-chip .pj-chip-img{width:{{ section.settings.chip_size | default: 96 | times: 2.0 | round }}px;height:{{ section.settings.chip_size | default: 96 | times: 1.0 | round }}px}
  }
  @media(max-width:560px){
    .pj-products{grid-template-columns:repeat(2,1fr);gap:22px 12px}
    .pj-line-section{padding:48px 16px 32px}
  }
</style>
 
<div class="pj-page">
 
  <section class="pj-category-head">
    <h1>{{ section.settings.titulo | default: page.title }}</h1>
    <p>{{ section.settings.descricao }}</p>
  </section>
 
  {%- comment -%} Filtro do topo: título + imagem pequena embaixo {%- endcomment -%}
  <div class="pj-lines-filter">
    <div class="pj-lines-filter-inner">
      <button class="pj-chip-arrow" onclick="pjScrollChips(-200)" aria-label="Anterior">‹</button>
      <div class="pj-chips" id="pj-chips">
        {%- for block in section.blocks -%}
          {%- if block.type == 'modelo' -%}
            {%- assign col = block.settings.colecao -%}
            {%- if col != blank -%}
              {%- assign line_title = block.settings.titulo | default: col.title -%}
              <a class="pj-chip" href="#linha-{{ col.handle }}">
                <span class="pj-chip-title">{{ line_title }}</span>
                <span class="pj-chip-img">
                  {%- if block.settings.img_topo -%}
                    <img src="{{ block.settings.img_topo | image_url: width: 320 }}" alt="{{ line_title | escape }}" loading="lazy">
                  {%- elsif block.settings.img_secao -%}
                    <img src="{{ block.settings.img_secao | image_url: width: 320 }}" alt="{{ line_title | escape }}" loading="lazy">
                  {%- elsif col.image -%}
                    <img src="{{ col.image | image_url: width: 320 }}" alt="{{ line_title | escape }}" loading="lazy">
                  {%- elsif col.products.first.featured_image -%}
                    <img src="{{ col.products.first.featured_image | image_url: width: 320 }}" alt="{{ line_title | escape }}" loading="lazy">
                  {%- endif -%}
                </span>
              </a>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
      <button class="pj-chip-arrow" onclick="pjScrollChips(200)" aria-label="Próximo">›</button>
    </div>
  </div>
 
  {%- comment -%} Uma seção por modelo: imagem + texto em cima, produtos embaixo (alternando esquerda/direita) {%- endcomment -%}
  {%- assign modelo_i = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'modelo' -%}
      {%- assign col = block.settings.colecao -%}
      {%- if col != blank -%}
        {%- assign line_title = block.settings.titulo | default: col.title -%}
        {%- assign modelo_i = modelo_i | plus: 1 -%}
        {%- assign resto = modelo_i | modulo: 2 -%}
        <section class="pj-line-section{% if resto == 0 %} pj-flip{% endif %}" id="linha-{{ col.handle }}" {{ block.shopify_attributes }}>
          <div class="pj-line-head">
            <div class="pj-line-img">
              {%- if block.settings.img_secao -%}
                <img src="{{ block.settings.img_secao | image_url: width: 1400 }}" alt="{{ line_title | escape }}" loading="lazy">
              {%- elsif col.image -%}
                <img src="{{ col.image | image_url: width: 1400 }}" alt="{{ line_title | escape }}" loading="lazy">
              {%- elsif col.products.first.featured_image -%}
                <img src="{{ col.products.first.featured_image | image_url: width: 1400 }}" alt="{{ line_title | escape }}" loading="lazy">
              {%- endif -%}
            </div>
            <div class="pj-line-info">
              <h2>{{ line_title }}</h2>
              <div class="pj-desc">
                {%- if block.settings.descricao != blank -%}
                  {{ block.settings.descricao }}
                {%- else -%}
                  {{ col.description }}
                {%- endif -%}
              </div>
            </div>
          </div>
          <div class="pj-products">
            {%- for product in col.products limit: section.settings.products_limit -%}
              <a class="pj-product" href="{{ product.url }}">
                <div class="pj-thumb">
                  {%- if product.featured_image -%}
                    <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" loading="lazy">
                  {%- endif -%}
                  {%- if section.settings.etiqueta != blank -%}
                    <span class="pj-tag">{{ section.settings.etiqueta }}</span>
                  {%- endif -%}
                </div>
                <h3>{{ product.title }}</h3>
                <div class="pj-price-row">
                  <div>
                    <div class="pj-price">{{ product.price | money }}</div>
                    {%- if section.settings.parcelas > 1 -%}
                      {%- assign pj_inst = product.price | divided_by: section.settings.parcelas -%}
                      <div class="pj-installments">{{ section.settings.parcelas }} x de {{ pj_inst | money }}</div>
                    {%- endif -%}
                  </div>
                </div>
                {%- if block.settings.acabamento != blank -%}
                  <div class="pj-finish">{{ block.settings.acabamento }}</div>
                {%- endif -%}
                <div class="pj-swatches">
                  <span class="pj-swatch amarelo" title="Ouro amarelo"></span>
                  <span class="pj-swatch branco" title="Ouro branco"></span>
                  <span class="pj-swatch rose" title="Ouro rosé"></span>
                </div>
              </a>
            {%- endfor -%}
          </div>
        </section>
      {%- elsif request.design_mode -%}
        <div class="pj-warn" {{ block.shopify_attributes }}>Bloco "Modelo" sem coleção: clique neste bloco e escolha uma coleção.</div>
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
 
  {%- comment -%} Bloco exclusivo Patrik {%- endcomment -%}
  {%- if section.settings.cta_titulo != blank -%}
    <section class="pj-cta">
      <h2>{{ section.settings.cta_titulo }}</h2>
      {%- if section.settings.cta_texto != blank -%}
        <p>{{ section.settings.cta_texto }}</p>
      {%- endif -%}
      {%- if section.settings.cta_botao != blank -%}
        {%- if section.settings.cta_modal != blank -%}
          <button class="pj-cta-btn" type="button" data-pj-modal="{{ section.settings.cta_modal | escape }}">{{ section.settings.cta_botao }}</button>
        {%- elsif section.settings.cta_link != blank -%}
          <a class="pj-cta-btn" href="{{ section.settings.cta_link }}">{{ section.settings.cta_botao }}</a>
        {%- else -%}
          <button class="pj-cta-btn" type="button" data-pj-chat="auto" data-pj-fallback="https://wa.me/5521974956097?text=Ol%C3%A1%2C%20gostaria%20de%20criar%20uma%20joia%20exclusiva%20com%20a%20Patrik">{{ section.settings.cta_botao }}</button>
        {%- endif -%}
      {%- endif -%}
    </section>
  {%- endif -%}
 
  {%- comment -%} FAQ: cada pergunta é um bloco editável {%- endcomment -%}
  {%- assign tem_pergunta = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'pergunta' %}{% assign tem_pergunta = true %}{% endif -%}
  {%- endfor -%}
  {%- if tem_pergunta -%}
    <section class="pj-faq">
      <div class="pj-faq-head">
        <h2>{{ section.settings.faq_titulo }}</h2>
        <p class="pj-sub">{{ section.settings.faq_subtitulo }}</p>
      </div>
      <div id="pj-accordion">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pergunta' and block.settings.pergunta != blank -%}
            <div class="pj-accordion-item" {{ block.shopify_attributes }}>
              <button class="pj-q">{{ block.settings.pergunta }}</button>
              <div class="pj-a"><p>{{ block.settings.resposta | newline_to_br }}</p></div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}
 
</div>
 
<script>
document.querySelectorAll(".pj-accordion-item").forEach(div => {
  div.querySelector(".pj-q").addEventListener("click", () => {
    const open = div.classList.toggle("open");
    div.querySelector(".pj-a").style.maxHeight = open ? div.querySelector(".pj-a").scrollHeight + "px" : 0;
  });
});
 
/* Botão do bloco Patrik: aciona o gatilho do modal de contato existente */
document.querySelectorAll("[data-pj-modal]").forEach(btn => {
  btn.addEventListener("click", () => {
    const alvo = document.querySelector(btn.dataset.pjModal);
    if (alvo) alvo.click();
  });
});
 
/* Detecção automática do chat/modal (bolinha do canto) */
document.querySelectorAll('[data-pj-chat="auto"]').forEach(btn => {
  btn.addEventListener("click", () => {
    try {
      if (window.tidioChatApi) { tidioChatApi.show(); tidioChatApi.open(); return; }
      if (window.jivo_api) { jivo_api.open(); return; }
      if (window.Tawk_API && Tawk_API.maximize) { Tawk_API.maximize(); return; }
      if (window.$crisp) { $crisp.push(["do","chat:open"]); return; }
      if (window.$zopim) { $zopim.livechat.window.show(); return; }
      if (window.HubSpotConversations) { HubSpotConversations.widget.open(); return; }
    } catch (e) {}
    const gatilhos = [
      ".chaty-button", "#chaty-widget", '[class*="chaty"] .cta-button',
      '[aria-label*="chat" i]', '[aria-label*="whatsapp" i]', '[aria-label*="contato" i]',
      ".floating-chat", ".chat-toggle", ".concierge-toggle", '[class*="concierge"]'
    ];
    for (const s of gatilhos) {
      const el = document.querySelector(s);
      if (el) { el.click(); return; }
    }
    if (btn.dataset.pjFallback) window.open(btn.dataset.pjFallback, "_blank");
  });
});
 
const pjChipsEl = document.getElementById("pj-chips");
function pjScrollChips(delta){ pjChipsEl.scrollBy({left:delta,behavior:"smooth"}); }
 
const pjSections = [...document.querySelectorAll(".pj-line-section")];
const pjChips = [...document.querySelectorAll(".pj-chip")];
window.addEventListener("scroll", () => {
  let current = 0;
  pjSections.forEach((s,i)=>{ if(s.getBoundingClientRect().top < 200) current = i; });
  pjChips.forEach((c,i)=>c.classList.toggle("active", i===current));
}, {passive:true});
</script>
 
{% schema %}
{
  "name": "Modelos de aliança",
  "settings": [
    {
      "type": "header",
      "content": "Topo da página"
    },
    {
      "type": "text",
      "id": "titulo",
      "label": "Título da página (vazio = usa o título da Page)"
    },
    {
      "type": "textarea",
      "id": "descricao",
      "label": "Descrição da página",
      "default": "Sua Aliança de Casamento em Ouro 18k Amarelo, Branco ou Rosé. Alianças de Casamento como eterno símbolo do amor. Envio de 3 a 7 dias."
    },
    {
      "type": "header",
      "content": "Modelos"
    },
    {
      "type": "text",
      "id": "etiqueta",
      "label": "Etiqueta na foto do produto (vazio = sem etiqueta)",
      "default": "Ouro 18k"
    },
    {
      "type": "range",
      "id": "chip_size",
      "label": "Tamanho da imagem do topo (bolinha)",
      "min": 48,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "img_width",
      "label": "Largura da imagem de cada modelo",
      "min": 300,
      "max": 720,
      "step": 20,
      "unit": "px",
      "default": 480
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Produtos por modelo",
      "min": 4,
      "max": 16,
      "step": 4,
      "default": 8
    },
    {
      "type": "range",
      "id": "parcelas",
      "label": "Número de parcelas exibidas (1 = não mostrar)",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 10
    },
    {
      "type": "header",
      "content": "Bloco Patrik (faixa antes do FAQ)"
    },
    {
      "type": "text",
      "id": "cta_titulo",
      "label": "Título (vazio = não mostrar o bloco)",
      "default": "Crie sua joia exclusiva"
    },
    {
      "type": "textarea",
      "id": "cta_texto",
      "label": "Texto",
      "default": "Alguns momentos merecem ser lembrados para sempre. Transformamos a sua história em uma aliança única, desenhada e produzida especialmente para vocês."
    },
    {
      "type": "text",
      "id": "cta_botao",
      "label": "Texto do botão",
      "default": "Fale com nossos especialistas"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link do botão (usado se o campo abaixo estiver vazio)"
    },
    {
      "type": "text",
      "id": "cta_modal",
      "label": "Seletor CSS do gatilho do modal (ex.: .chat-button)",
      "info": "Se preenchido, o botão abre o modal de contato do site em vez de navegar para o link."
    },
    {
      "type": "header",
      "content": "Perguntas frequentes"
    },
    {
      "type": "text",
      "id": "faq_titulo",
      "label": "Título do FAQ",
      "default": "Questions"
    },
    {
      "type": "text",
      "id": "faq_subtitulo",
      "label": "Subtítulo do FAQ",
      "default": "Algumas das perguntas recorrentes enviadas por nossos clientes."
    }
  ],
  "blocks": [
    {
      "type": "modelo",
      "name": "Modelo de aliança",
      "settings": [
        {
          "type": "collection",
          "id": "colecao",
          "label": "Coleção do modelo"
        },
        {
