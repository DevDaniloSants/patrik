<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
 
<style>
  .pj-page{
    --pj-gold:#b39055; --pj-ink:#1e1e1e; --pj-grey:#6f6f6f;
    --pj-line:#e8e2d8; --pj-soft:#faf7f2;
    --pj-serif:'Cormorant Garamond',serif; --pj-sans:'Jost',sans-serif;
    font-family:var(--pj-sans); color:var(--pj-ink); font-weight:300;
  }
  .pj-page *{margin:0;padding:0;box-sizing:border-box}
  .pj-page a{color:inherit;text-decoration:none}
  .pj-page button{font-family:inherit;cursor:pointer}
  .pj-page img{display:block;max-width:100%}
 
  /* Cabeçalho da categoria */
  .pj-category-head{text-align:center;padding:54px 24px 20px;background:var(--pj-soft)}
  .pj-breadcrumb{font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--pj-grey);margin-bottom:22px}
  .pj-category-head h1{font-family:var(--pj-serif);font-weight:500;font-size:44px;letter-spacing:.03em;margin-bottom:14px}
  .pj-category-head>p{max-width:640px;margin:0 auto;color:var(--pj-grey);font-size:15.5px;line-height:1.7}
 
  /* Filtro de modelos (título + imagem pequena embaixo) */
  .pj-lines-filter{position:sticky;top:0;z-index:30;background:var(--pj-soft);border-bottom:1px solid var(--pj-line);padding:16px 0 14px}
  .pj-lines-filter-inner{max-width:1280px;margin:0 auto;display:flex;align-items:center;gap:8px;padding:0 16px}
  .pj-chips{display:flex;gap:22px;overflow-x:auto;scrollbar-width:none;padding:2px 6px;margin:0 auto}
  .pj-chips::-webkit-scrollbar{display:none}
  .pj-chip{flex:0 0 auto;display:flex;flex-direction:column;align-items:center;gap:8px;padding:4px 2px}
  .pj-chip .pj-chip-title{font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--pj-ink);border-bottom:1px solid transparent;padding-bottom:2px;transition:.25s;white-space:nowrap}
  .pj-chip .pj-chip-img{width:62px;height:62px;border-radius:50%;overflow:hidden;border:1px solid var(--pj-line);background:#fff;transition:.25s}
  .pj-chip .pj-chip-img img{width:100%;height:100%;object-fit:cover}
  .pj-chip:hover .pj-chip-img,.pj-chip.active .pj-chip-img{border-color:var(--pj-gold);box-shadow:0 0 0 1px var(--pj-gold)}
  .pj-chip:hover .pj-chip-title,.pj-chip.active .pj-chip-title{color:var(--pj-gold);border-color:var(--pj-gold)}
  .pj-chip-arrow{flex:0 0 auto;width:32px;height:32px;border-radius:50%;border:1px solid var(--pj-line);background:#fff;color:var(--pj-grey);display:none;align-items:center;justify-content:center}
 
  /* Seções: imagem + texto em cima, produtos embaixo */
  .pj-line-section{max-width:1280px;margin:0 auto;padding:64px 24px 40px;border-bottom:1px solid var(--pj-line)}
  .pj-line-head{display:grid;grid-template-columns:380px 1fr;gap:44px;align-items:center;margin-bottom:40px}
  .pj-line-img{aspect-ratio:4/5;background:var(--pj-soft);border-radius:2px;overflow:hidden}
  .pj-line-img img{width:100%;height:100%;object-fit:cover}
  .pj-line-info .pj-eyebrow{display:flex;align-items:center;gap:8px;font-size:11.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--pj-gold);margin-bottom:12px}
  .pj-line-info .pj-eyebrow::before{content:"";width:26px;height:1px;background:var(--pj-gold)}
  .pj-line-info h2{font-family:var(--pj-serif);font-weight:500;font-size:38px;margin-bottom:14px}
  .pj-line-info .pj-desc{color:var(--pj-grey);font-size:15px;line-height:1.75;max-width:680px}
 
  /* Grade: 4 no desktop, 2 no mobile */
  .pj-products{display:grid;grid-template-columns:repeat(4,1fr);gap:28px 20px}
  .pj-product{text-align:center;display:block}
  .pj-product .pj-thumb{position:relative;aspect-ratio:4/5;background:var(--pj-soft);border-radius:2px;overflow:hidden;margin-bottom:14px}
  .pj-product .pj-thumb img{width:100%;height:100%;object-fit:cover;transition:transform .5s}
  .pj-product:hover .pj-thumb img{transform:scale(1.05)}
  .pj-product .pj-tag{position:absolute;top:10px;left:10px;background:#fff;font-size:10px;letter-spacing:.14em;text-transform:uppercase;padding:4px 10px;color:var(--pj-grey)}
  .pj-product h3{font-weight:400;font-size:13.5px;line-height:1.5;letter-spacing:.02em;min-height:3em;margin-bottom:8px}
  .pj-product .pj-price{font-size:16px;font-weight:500}
  .pj-product .pj-installments{font-size:12px;color:var(--pj-grey);margin-top:2px}
  .pj-swatches{display:flex;justify-content:center;gap:7px;margin-top:10px}
  .pj-swatch{width:16px;height:16px;border-radius:50%;border:1px solid #fff;box-shadow:0 0 0 1px var(--pj-line)}
  .pj-swatch.amarelo{background:linear-gradient(135deg,#e8c977,#c9a24d)}
  .pj-swatch.branco{background:linear-gradient(135deg,#f2f2f0,#c9c9c4)}
  .pj-swatch.rose{background:linear-gradient(135deg,#eec3ad,#d49678)}
 
  .pj-warn{max-width:1280px;margin:20px auto;padding:14px 18px;border:1px dashed var(--pj-gold);color:var(--pj-grey);font-size:13.5px}
 
  /* FAQ */
  .pj-faq{max-width:880px;margin:0 auto;padding:80px 24px}
  .pj-faq h2{font-family:var(--pj-serif);font-weight:500;font-size:36px;text-align:center;letter-spacing:.08em;margin-bottom:8px}
  .pj-faq .pj-sub{text-align:center;color:var(--pj-grey);font-size:14.5px;margin-bottom:44px}
  .pj-accordion-item{border-bottom:1px solid var(--pj-line)}
  .pj-accordion-item button.pj-q{width:100%;background:none;border:none;text-align:left;display:flex;justify-content:space-between;align-items:center;gap:16px;padding:22px 4px;font-size:16.5px;font-weight:400;color:var(--pj-ink)}
  .pj-accordion-item button.pj-q::after{content:"+";font-family:var(--pj-serif);font-size:26px;color:var(--pj-gold);transition:.3s}
  .pj-accordion-item.open button.pj-q::after{transform:rotate(45deg)}
  .pj-accordion-item .pj-a{max-height:0;overflow:hidden;transition:max-height .4s ease}
  .pj-accordion-item .pj-a p{padding:0 4px 24px;color:var(--pj-grey);font-size:14.5px;line-height:1.8}
 
  @media(max-width:1024px){
    .pj-line-head{grid-template-columns:1fr;gap:24px}
    .pj-line-img{max-width:520px;width:100%;margin:0 auto}
    .pj-products{grid-template-columns:repeat(3,1fr)}
  }
  @media(max-width:860px){
    .pj-category-head h1{font-size:34px}
    .pj-line-info h2{font-size:30px}
    /* setinhas do filtro: apenas no mobile */
    .pj-chip-arrow{display:flex}
    .pj-chips{margin:0}
    .pj-chip .pj-chip-img{width:52px;height:52px}
  }
  @media(max-width:560px){
    .pj-products{grid-template-columns:repeat(2,1fr);gap:22px 12px}
  }
</style>
 
<div class="pj-page">
 
  <section class="pj-category-head">
    <div class="pj-breadcrumb"><a href="/">Início</a> &nbsp;›&nbsp; {{ page.title }}</div>
    <h1>{{ section.settings.titulo | default: page.title }}</h1>
    <p>{{ section.settings.descricao }}</p>
  </section>
 
  {%- comment -%} Filtro do topo: título + imagem pequena embaixo {%- endcomment -%}
  <div class="pj-lines-filter">
    <div class="pj-lines-filter-inner">
      <button class="pj-chip-arrow" onclick="pjScrollChips(-200)" aria-label="Anterior">‹</button>
      <div class="pj-chips" id="pj-chips">
        {%- for block in section.blocks -%}
          {%- if block.type == 'modelo' -%}
            {%- assign col = block.settings.colecao -%}
            {%- if col != blank -%}
              {%- assign line_title = block.settings.titulo | default: col.title -%}
              <a class="pj-chip" href="#linha-{{ col.handle }}">
                <span class="pj-chip-title">{{ line_title }}</span>
                <span class="pj-chip-img">
                  {%- if block.settings.img_topo -%}
                    <img src="{{ block.settings.img_topo | image_url: width: 140 }}" alt="{{ line_title | escape }}" loading="lazy">
                  {%- elsif block.settings.img_secao -%}
                    <img src="{{ block.settings.img_secao | image_url: width: 140 }}" alt="{{ line_title | escape }}" loading="lazy">
                  {%- elsif col.image -%}
                    <img src="{{ col.image | image_url: width: 140 }}" alt="{{ line_title | escape }}" loading="lazy">
                  {%- elsif col.products.first.featured_image -%}
                    <img src="{{ col.products.first.featured_image | image_url: width: 140 }}" alt="{{ line_title | escape }}" loading="lazy">
                  {%- endif -%}
                </span>
              </a>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
      <button class="pj-chip-arrow" onclick="pjScrollChips(200)" aria-label="Próximo">›</button>
    </div>
  </div>
 
  {%- comment -%} Uma seção por modelo: imagem + texto em cima, produtos embaixo {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'modelo' -%}
      {%- assign col = block.settings.colecao -%}
      {%- if col != blank -%}
        {%- assign line_title = block.settings.titulo | default: col.title -%}
        <section class="pj-line-section" id="linha-{{ col.handle }}" {{ block.shopify_attributes }}>
          <div class="pj-line-head">
            <div class="pj-line-img">
              {%- if block.settings.img_secao -%}
                <img src="{{ block.settings.img_secao | image_url: width: 900 }}" alt="{{ line_title | escape }}" loading="lazy">
              {%- elsif col.image -%}
                <img src="{{ col.image | image_url: width: 900 }}" alt="{{ line_title | escape }}" loading="lazy">
              {%- elsif col.products.first.featured_image -%}
                <img src="{{ col.products.first.featured_image | image_url: width: 900 }}" alt="{{ line_title | escape }}" loading="lazy">
              {%- endif -%}
            </div>
            <div class="pj-line-info">
              <div class="pj-eyebrow">{{ section.settings.eyebrow }}</div>
              <h2>{{ line_title }}</h2>
              <div class="pj-desc">
                {%- if block.settings.descricao != blank -%}
                  {{ block.settings.descricao }}
                {%- else -%}
                  {{ col.description }}
                {%- endif -%}
              </div>
            </div>
          </div>
          <div class="pj-products">
            {%- for product in col.products limit: section.settings.products_limit -%}
              <a class="pj-product" href="{{ product.url }}">
                <div class="pj-thumb">
                  {%- if product.featured_image -%}
                    <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" loading="lazy">
                  {%- endif -%}
                  {%- if section.settings.etiqueta != blank -%}
                    <span class="pj-tag">{{ section.settings.etiqueta }}</span>
                  {%- endif -%}
                </div>
                <h3>{{ product.title }}</h3>
                <div class="pj-price">{{ product.price | money }}</div>
                {%- if section.settings.parcelas > 1 -%}
                  {%- assign pj_inst = product.price | divided_by: section.settings.parcelas -%}
                  <div class="pj-installments">{{ section.settings.parcelas }} x de {{ pj_inst | money }}</div>
                {%- endif -%}
                <div class="pj-swatches">
                  <span class="pj-swatch amarelo" title="Ouro amarelo"></span>
                  <span class="pj-swatch branco" title="Ouro branco"></span>
                  <span class="pj-swatch rose" title="Ouro rosé"></span>
                </div>
              </a>
            {%- endfor -%}
          </div>
        </section>
      {%- elsif request.design_mode -%}
        <div class="pj-warn" {{ block.shopify_attributes }}>Bloco "Modelo" sem coleção: clique neste bloco e escolha uma coleção.</div>
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
 
  {%- comment -%} FAQ: cada pergunta é um bloco editável {%- endcomment -%}
  {%- assign tem_pergunta = false -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'pergunta' %}{% assign tem_pergunta = true %}{% endif -%}
  {%- endfor -%}
  {%- if tem_pergunta -%}
    <section class="pj-faq">
      <h2>{{ section.settings.faq_titulo }}</h2>
      <p class="pj-sub">{{ section.settings.faq_subtitulo }}</p>
      <div id="pj-accordion">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pergunta' and block.settings.pergunta != blank -%}
            <div class="pj-accordion-item" {{ block.shopify_attributes }}>
              <button class="pj-q">{{ block.settings.pergunta }}</button>
              <div class="pj-a"><p>{{ block.settings.resposta | newline_to_br }}</p></div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}
 
</div>
 
<script>
document.querySelectorAll(".pj-accordion-item").forEach(div => {
  div.querySelector(".pj-q").addEventListener("click", () => {
    const open = div.classList.toggle("open");
    div.querySelector(".pj-a").style.maxHeight = open ? div.querySelector(".pj-a").scrollHeight + "px" : 0;
  });
});
 
const pjChipsEl = document.getElementById("pj-chips");
function pjScrollChips(delta){ pjChipsEl.scrollBy({left:delta,behavior:"smooth"}); }
 
const pjSections = [...document.querySelectorAll(".pj-line-section")];
const pjChips = [...document.querySelectorAll(".pj-chip")];
window.addEventListener("scroll", () => {
  let current = 0;
  pjSections.forEach((s,i)=>{ if(s.getBoundingClientRect().top < 200) current = i; });
  pjChips.forEach((c,i)=>c.classList.toggle("active", i===current));
}, {passive:true});
</script>
 
{% schema %}
{
  "name": "Modelos de aliança",
  "settings": [
    {
      "type": "header",
      "content": "Topo da página"
    },
    {
      "type": "text",
      "id": "titulo",
      "label": "Título da página (vazio = usa o título da Page)"
    },
    {
      "type": "textarea",
      "id": "descricao",
      "label": "Descrição da página",
      "default": "Sua Aliança de Casamento em Ouro 18k Amarelo, Branco ou Rosé. Alianças de Casamento como eterno símbolo do amor. Envio de 3 a 7 dias."
    },
    {
      "type": "header",
      "content": "Modelos"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeno acima do nome do modelo",
      "default": "Aliança de Casamento"
    },
    {
      "type": "text",
      "id": "etiqueta",
      "label": "Etiqueta na foto do produto (vazio = sem etiqueta)",
      "default": "Ouro 18k"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Produtos por modelo",
      "min": 4,
      "max": 16,
      "step": 4,
      "default": 8
    },
    {
      "type": "range",
      "id": "parcelas",
      "label": "Número de parcelas exibidas (1 = não mostrar)",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 10
    },
    {
      "type": "header",
      "content": "Perguntas frequentes"
    },
    {
      "type": "text",
      "id": "faq_titulo",
      "label": "Título do FAQ",
      "default": "Questions"
    },
    {
      "type": "text",
      "id": "faq_subtitulo",
      "label": "Subtítulo do FAQ",
      "default": "Algumas das perguntas recorrentes enviadas por nossos clientes."
    }
  ],
  "blocks": [
    {
      "type": "modelo",
      "name": "Modelo de aliança",
      "settings": [
        {
          "type": "collection",
          "id": "colecao",
          "label": "Coleção do modelo"
        },
        {
          "type": "text",
          "id": "titulo",
          "label": "Nome do modelo (vazio = usa o nome da coleção)"
        },
        {
          "type": "textarea",
          "id": "descricao",
          "label": "Descrição do modelo (vazio = usa a descrição da coleção)"
        },
        {
          "type": "image_picker",
          "id": "img_topo",
          "label": "Imagem pequena do topo (bolinha)"
        },
        {
          "type": "image_picker",
          "id": "img_secao",
          "label": "Imagem grande da seção"
        }
      ]
    },
    {
      "type": "pergunta",
      "name": "Pergunta (FAQ)",
      "settings": [
        {
          "type": "text",
          "id": "pergunta",
          "label": "Pergunta"
        },
        {
          "type": "textarea",
          "id": "resposta",
          "label": "Resposta"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Modelos de aliança",
      "blocks": [
        { "type": "modelo" },
        { "type": "modelo" },
        { "type": "modelo" },
        { "type": "modelo" },
        { "type": "modelo" },
        { "type": "modelo" },
        { "type": "modelo" },
        { "type": "pergunta" },
        { "type": "pergunta" },
        { "type": "pergunta" }
      ]
    }
  ]
}
{% endschema %}>