<style>
  .vbc-hero-outer {
    position: relative;
    width: 100%;
  }

  .vbc-hero-wrapper {
    position: relative;
    width: 100vw;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    overflow: hidden;

    {% case section.settings.section_height %}
      {% when 'full' %}
        height: 100vh;
      {% when 'three-quarters' %}
        height: 75vh;
      {% when 'half' %}
        height: 50vh;
      {% when 'auto' %}
        height: auto;
        min-height: 400px;
    {% endcase %}
  }

  .vbc-video {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    transform: translate(-50%, -50%);
    object-fit: cover;
    pointer-events: none;
  }
  .vbc-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});
  }
  .vbc-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: {{ section.settings.text_horizontal }};
    justify-content: {{ section.settings.text_vertical }};
    text-align: {{ section.settings.text_align }};
    padding: 2rem;
    color: #fff;
  }
  .vbc-title {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }
  .vbc-subtitle {
    font-size: 1.2rem;
    margin-bottom: 2rem;
    opacity: 0.9;
  }
  .vbc-btn {
    display: inline-block;
    padding: 0.8rem 2rem;
    background: {{ section.settings.button_color }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    font-size: 1rem;
    border-radius: 4px;
    transition: opacity 0.2s;
  }
  .vbc-btn:hover { opacity: 0.85; }
</style>

{% if section.settings.hero_mode %}
<style>
  #shopify-section-{{ section.id }} {
    margin-top: calc(-1 * var(--header-height, 80px));
    position: relative;
    z-index: 1;
  }
</style>
{% endif %}

<div class="vbc-hero-outer">
  <div class="vbc-hero-wrapper">
    {% if section.settings.video_shopify.sources != blank %}
      <video class="vbc-video" autoplay loop muted playsinline disablepictureinpicture>
        {% for source in section.settings.video_shopify.sources %}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {% endfor %}
      </video>
    {% elsif section.settings.video_url != blank %}
      <video class="vbc-video" autoplay loop muted playsinline disablepictureinpicture>
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {% endif %}
    <div class="vbc-overlay"></div>
    <div class="vbc-content">
      {% if section.settings.title != blank %}
        <h2 class="vbc-title">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="vbc-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
      {% if section.settings.button_label != blank and section.settings.button_url != blank %}
        <a class="vbc-btn" href="{{ section.settings.button_url }}">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Video Hero Custom",
  "settings": [
    {
      "type": "checkbox",
      "id": "hero_mode",
      "label": "Modo Hero (cobre o cabeçalho)",
      "default": true
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Altura da seção",
      "options": [
        { "value": "full", "label": "Tela inteira (100vh)" },
        { "value": "three-quarters", "label": "3/4 da tela (75vh)" },
        { "value": "half", "label": "Metade da tela (50vh)" },
        { "value": "auto", "label": "Automático (conteúdo)" }
      ],
      "default": "full"
    },
    {
      "type": "video",
      "id": "video_shopify",
      "label": "Vídeo (upload direto)"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "URL do vídeo (.mp4) — alternativa ao upload",
      "info": "Usado apenas se nenhum vídeo for enviado acima"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacidade do overlay (%)",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30
    },
    {
      "type": "select",
      "id": "text_horizontal",
      "label": "Posição horizontal do texto",
      "options": [
        { "value": "flex-start", "label": "Esquerda" },
        { "value": "center", "label": "Centro" },
        { "value": "flex-end", "label": "Direita" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Alinhamento do texto",
      "options": [
        { "value": "left", "label": "Esquerda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Direita" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_vertical",
      "label": "Posição vertical do texto",
      "options": [
        { "value": "flex-start", "label": "Topo" },
        { "value": "center", "label": "Meio" },
        { "value": "flex-end", "label": "Baixo" }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Seu título aqui"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Seu subtítulo aqui"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto do botão",
      "default": "Saiba mais"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Link do botão"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Cor do botão",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Cor do texto do botão",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Video Hero Custom"
    }
  ]
}
{% endschema %}
