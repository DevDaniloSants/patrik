<!-- /sections/section-columns.liquid -->

{% assign columns_specialist_modal_id = 'specialist-modal-columns-' | append: section.id %}
{% assign columns_has_specialist_modal_button = false %}

<div class="section-columns {{ section.settings.bg }}"
  data-section-id="{{ section.id }}"
  data-section-type="section-columns"
  style="--PT: {{ section.settings.padding_top }}px; --PB: {{ section.settings.padding_bottom }}px;">
  <div class="{{ section.settings.width }} section-padding">
    {% if section.settings.title != blank %}
      <h2 class="kicker-flourished mb-r11">{{ section.settings.title | escape }}</h2>
    {% endif %}
    <div
      data-grid
      data-grid-flex
      data-grid-large
      data-grid-medium
      data-grid-small
      data-custom-scrollbar-items
      style="
        --grid-large-items: {{ section.settings.grid_large }};
        --grid-medium-items: {{ section.settings.grid_medium }};
        --grid-small-items: {{ section.settings.grid_mobile }};">
      {% for block in section.blocks %}
				{% if block.settings.open_specialist_modal %}
					{% assign columns_has_specialist_modal_button = true %}
				{% endif %}
        <div
          class="index__column grid__item slide-item {{ section.settings.align_text }}"
          data-item
					{% if block.settings.open_specialist_modal %}
						role="button"
						tabindex="0"
						onclick="var m=document.getElementById('{{ columns_specialist_modal_id }}');if(m){var card=m.querySelector('.specialist-modal__card');var backdrop=m.querySelector('[style*=backdrop-filter]');if(card){card.style.display='';}if(backdrop){backdrop.style.display='';}m.classList.add('specialist-modal--open');m.style.display='flex';}"
						onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();var m=document.getElementById('{{ columns_specialist_modal_id }}');if(m){var card=m.querySelector('.specialist-modal__card');var backdrop=m.querySelector('[style*=backdrop-filter]');if(card){card.style.display='';}if(backdrop){backdrop.style.display='';}m.classList.add('specialist-modal--open');m.style.display='flex';}}"
						style="cursor:pointer;"
					{% endif %}
          {{ block.shopify_attributes }}>
          {% if block.settings.enable_image %}
            <div class="column__image" data-grid-slide>
              {%- capture sizes -%}
                {%- render 'image-grid-sizes',
                  columns_desktop: section.settings.grid_large,
                  columns_tablet: section.settings.grid_large,
                  columns_mobile: section.settings.grid_mobile,
                  section_width: section.settings.width
                %}
              {%- endcapture -%}

              {%- capture srcset -%}
                {%- render 'image-grid-srcset',
                  image: block.settings.image,
                  columns_desktop: section.settings.grid_large,
                  columns_tablet: section.settings.grid_large,
                  columns_mobile: section.settings.grid_mobile,
                  section_width: section.settings.width
                %}
              {%- endcapture -%}

              {%- if section.settings.scale_image -%}
                {%- render 'image', cover: true, img_object: block.settings.image, srcset: srcset, sizes: sizes, loading: 'lazy', class: block.settings.shape_class, wh_ratio: section.settings.wh_ratio -%}
              {%- else -%}
                {%- render 'image', cover: true, img_object: block.settings.image, srcset: srcset, sizes: sizes, loading: 'lazy', class: block.settings.shape_class -%}
              {%- endif -%}
              {% comment %}
                If there is a video add a play button over the image
                If there is a non video link and no button label just
                link the image to the link destination
              {% endcomment %}
              {%- if block.settings.enable_video -%}
                <div class="{{ block.settings.video_button_color }}">
                  {%- render 'video-popup', video: block.settings.video_link, unique: block.id -%}
                </div>
							{%- elsif block.settings.open_specialist_modal == false and block.settings.button_label == blank and block.settings.button_link != blank -%}
                <a class="link-over-image" href="{{ block.settings.button_link }}" aria-label="{{ block.settings.title | strip_html | escape }}"></a>
              {%- endif -%}
            </div>
          {% endif %}
          {% if block.settings.title != blank %}
            <div class="accent-title-large strong mb-r4">{{ block.settings.title | escape }}</div>
          {% endif %}
          {% if block.settings.text != blank %}
            <div class="rte body-size-4">{{ block.settings.text }}</div>
          {% endif %}
					{% if block.settings.button_label != blank %}
						{% if block.settings.open_specialist_modal %}
							<button
								type="button"
								class="{{ block.settings.button_color }} {{ block.settings.button_style }}"
								onclick="var m=document.getElementById('{{ columns_specialist_modal_id }}');if(m){var card=m.querySelector('.specialist-modal__card');var backdrop=m.querySelector('[style*=backdrop-filter]');if(card){card.style.display='';}if(backdrop){backdrop.style.display='';}m.classList.add('specialist-modal--open');m.style.display='flex';}">
								{{ block.settings.button_label | escape }}
							</button>
						{% elsif block.settings.button_link != blank %}
							<a href="{{ block.settings.button_link }}" class="{{ block.settings.button_color }} {{ block.settings.button_style }}">
								{{ block.settings.button_label | escape }}
							</a>
						{% endif %}
          {% endif %}
        </div>
      {% endfor %}
    </div>
    {%- if section.settings.progress_bar_mobile -%}
      <div class="custom-scrollbar small-down--show" data-custom-scrollbar>
        <div class="custom-scrollbar__track" data-custom-scrollbar-track></div>
      </div>
    {%- endif -%}

    {% if section.blocks.size == 0 %}
      <div class="text-center">{{ 'home_page.onboarding.no_content' | t }}</div>
    {% endif %}
  </div>
</div>

{% if columns_has_specialist_modal_button %}
	<div
		id="{{ columns_specialist_modal_id }}"
		role="dialog"
		aria-modal="true"
		aria-label="Escolha um canal de contato"
		style="display:none; position:fixed; inset:0; z-index:99999; align-items:center; justify-content:center; padding:16px;"
		onclick="if(event.target===this){this.classList.remove('specialist-modal--open');this.style.display='none';}">
		<div style="position:absolute; inset:0; background:rgba(0,0,0,0.45); backdrop-filter:blur(2px);"></div>

		<div class="specialist-modal__card lg:rounded-[20px]!" style="position:relative; background:#fff; padding:36px 32px 28px; max-width:420px; width:100%; text-align:center;">
			<div class="specialist-modal__handle" style="display:none; width:36px; height:4px; background:#ddd; border-radius:9999px; margin:0 auto 20px;"></div>

			<button
				type="button"
				aria-label="Fechar"
				onclick="var m=this.closest('[id^=specialist-modal-]');if(m){m.classList.remove('specialist-modal--open');m.style.display='none';}"
				style="position:absolute; top:13px; right:16px; background:none; border:none; cursor:pointer; color:#666; padding:4px; display:flex; align-items:center;">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
				</svg>
			</button>

			<span style="font-size:14px; font-weight:600; color:#111; margin:0 0 8px; line-height:1.3;">Escolha um canal de contato de sua preferencia</span>

			<a
				href="https://wa.me/5511999999999"
				target="_blank"
				rel="noopener noreferrer"
				onclick="var m=this.closest('[id^=specialist-modal-]');if(m){m.classList.remove('specialist-modal--open');m.style.display='none';}"
				style="display:flex; margin-top: 15px; align-items:center; justify-content:center; gap:10px; width:100%; padding:14px 20px; background:#25D366; color:#fff; border-radius:9999px; font-size:14px; font-weight:600; text-decoration:none; margin-bottom:12px; transition:background 0.2s, transform 0.15s;">
				Falar pelo WhatsApp
			</a>

			<button
				type="button"
				style="display:flex; align-items:center; justify-content:center; gap:10px; width:100%; padding:14px 20px; background:#111; color:#fff; border-radius:9999px; font-size:14px; font-weight:600; border:none; cursor:pointer; transition:background 0.2s, transform 0.15s;"
				onclick="var m=this.closest('[id^=specialist-modal-]');if(m){m.classList.remove('specialist-modal--open');m.style.display='none';}var inboxChat=document.querySelector('inbox-online-store-chat')||window.ShopifyChat;if(inboxChat&&inboxChat.tagName&&inboxChat.tagName.toLowerCase()==='inbox-online-store-chat'){inboxChat.setAttribute('is-open','true');if(inboxChat.shadowRoot){var shadowBtn=inboxChat.shadowRoot.querySelector('button');if(shadowBtn)shadowBtn.click();}}">
				Falar pelo Chat
			</button>
		</div>
	</div>

	<style>
		#{{ columns_specialist_modal_id }} { display: none; }
		#{{ columns_specialist_modal_id }}.specialist-modal--open { display: flex !important; }

		@media (max-width: 767px) {
			#{{ columns_specialist_modal_id }} {
				align-items: flex-end !important;
				padding: 0 !important;
			}

			#{{ columns_specialist_modal_id }} .specialist-modal__card {
				max-width: 100% !important;
				width: 100% !important;
				padding: 20px 24px 32px !important;
			}

			#{{ columns_specialist_modal_id }} .specialist-modal__handle {
				display: block !important;
			}
		}
	</style>

	<script>
		(function() {
			var modalId = '{{ columns_specialist_modal_id }}';
			function teleportModal() {
				var modal = document.getElementById(modalId);
				if (modal && modal.parentNode !== document.body) {
					document.body.appendChild(modal);
				}
			}
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', teleportModal);
			} else {
				teleportModal();
			}
		})();
	</script>
{% endif %}

{% schema %}
{
	"name": "Text columns with images",
	"settings": [
		{
			"type": "text",
			"id": "title",
			"label": "Kicker",
			"default": "Text columns with images"
		},
		{
			"type": "select",
			"id": "bg",
			"label": "Background color",
			"default": "palette--light bg--neutral",
			"options": [
				{
					"value": "palette--light bg--neutral",
					"label": "Default"
				},
				{
					"value": "palette--light bg--accent",
					"label": "Light"
				},
				{
					"value": "palette--dark bg--invert",
					"label": "Dark"
				},
				{
					"value": "palette--dark bg--invert--accent",
					"label": "Dark accent"
				},
				{
					"value": "palette--bright bg--bright",
					"label": "Bright"
				},
				{
					"value": "palette--bright bg--bright--accent",
					"label": "Bright accent"
				}
			]
		},
		{
			"type": "select",
			"id": "align_text",
			"label": "Text alignment",
			"default": "text-center",
			"options": [
				{
					"value": "text-left",
					"label": "Left"
				},
				{
					"value": "text-center",
					"label": "Centered"
				},
				{
					"value": "text-right",
					"label": "Right"
				}
			]
		},
		{
			"type": "header",
			"content": "Images"
		},
		{
			"type": "checkbox",
			"id": "scale_image",
			"label": "Scale images",
			"default": true
		},
		{
			"type": "range",
			"id": "wh_ratio",
			"min": 0.5,
			"max": 5,
			"step": 0.1,
			"unit": ":1",
			"label": "Image scaling ratio",
			"default": 1
		},
		{
			"type": "header",
			"content": "Items per row"
		},
		{
			"type": "range",
			"id": "grid_large",
			"min": 3,
			"max": 6,
			"step": 1,
			"label": "Desktop",
			"default": 3
		},
		{
			"type": "range",
			"id": "grid_medium",
			"min": 1,
			"max": 4,
			"step": 1,
			"label": "Tablet",
			"default": 3
		},
		{
			"type": "range",
			"id": "grid_mobile",
			"min": 1,
			"max": 3,
			"step": 0.1,
			"label": "Mobile",
			"default": 1.2
		},
		{
			"type": "checkbox",
			"id": "progress_bar_mobile",
			"label": "Show mobile scrollbar",
			"default": false
		},
		{
			"type": "header",
			"content": "Section spacing"
		},
		{
			"type": "select",
			"id": "width",
			"label": "Width",
			"default": "wrapper",
			"options": [
				{
					"value": "wrapper--full",
					"label": "Full width padded"
				},
				{
					"value": "wrapper",
					"label": "Page width"
				},
				{
					"value": "wrapper--narrow",
					"label": "Page width narrow"
				},
				{
					"value": "wrapper--tiny",
					"label": "Page width extra narrow"
				}
			]
		},
		{
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 180,
			"step": 2,
			"unit": "px",
			"label": "Padding top",
			"default": 36
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 180,
			"step": 2,
			"unit": "px",
			"label": "Padding bottom",
			"default": 36
		}
	],
	"blocks": [
		{
			"type": "text_block",
			"name": "Column",
			"settings": [
				{
					"type": "checkbox",
					"id": "enable_image",
					"label": "Show image",
					"default": true
				},
				{
					"type": "image_picker",
					"id": "image",
					"label": "Image"
				},
				{
					"type": "select",
					"id": "shape_class",
					"label": "Shape",
					"default": "",
					"options": [
						{
							"value": "",
							"label": "None"
						},
						{
							"value": "rounded-lg",
							"label": "Rounded"
						},
						{
							"value": "radius-keyhole",
							"label": "Keyhole"
						},
						{
							"value": "rounded-full",
							"label": "Circle"
						},
						{
							"value": "clip-sunburst",
							"label": "Sunburst"
						},
						{
							"value": "clip-hexagon",
							"label": "Hexagon"
						},
						{
							"value": "clip-octagon",
							"label": "Octagon"
						},
						{
							"value": "clip-parallelogram",
							"label": "Parallelogram"
						},
						{
							"value": "radius-blob-1",
							"label": "Blob 1"
						},
						{
							"value": "radius-blob-2",
							"label": "Blob 2"
						},
						{
							"value": "radius-blob-3",
							"label": "Blob 3"
						},
						{
							"value": "radius-blob-4",
							"label": "Blob 4"
						},
						{
							"value": "mask-stamp-sharp",
							"label": "Stamp sharp"
						},
						{
							"value": "mask-stamp-rounded",
							"label": "Stamp rounded"
						},
						{
							"value": "mask-ticket-stub",
							"label": "Ticket"
						}
					]
				},
				{
					"type": "text",
					"id": "title",
					"label": "Title",
					"default": "Feature images or videos"
				},
				{
					"type": "richtext",
					"id": "text",
					"label": "Text",
					"default": "<p>Add a video popup link to show a play button.  Share blog posts, products, or promotions with your customers. Use this text to describe products, share details on availability and style, or as a space to display recent reviews or FAQs.</p>"
				},
				{
					"type": "text",
					"id": "button_label",
					"label": "Button label",
					"info": "Leave blank to link from image"
				},
				{
					"type": "url",
					"id": "button_link",
					"label": "Button link"
				},
				{
					"type": "checkbox",
					"id": "open_specialist_modal",
					"label": "Abrir modal de especialista (em vez do link)",
					"default": false
				},
				{
					"type": "select",
					"id": "button_color",
					"label": "Color",
					"default": "btn--neutral",
					"options": [
						{
							"value": "btn--primary",
							"label": "Bright accent"
						},
						{
							"value": "btn--secondary",
							"label": "Secondary accent"
						},
						{
							"value": "btn--neutral",
							"label": "Text color"
						},
						{
							"value": "btn--black",
							"label": "Black"
						},
						{
							"value": "btn--white",
							"label": "White"
						}
					]
				},
				{
					"type": "select",
					"id": "button_style",
					"label": "Button style",
					"default": "btn--soft",
					"options": [
						{
							"value": "btn-text-thick-line",
							"label": "Capitalized text"
						},
						{
							"value": "btn",
							"label": "Solid button"
						},
						{
							"value": "btn--soft",
							"label": "Soft button"
						},
						{
							"value": "btn--outline",
							"label": "Outlined button"
						}
					]
				},
				{
					"type": "header",
					"content": "Video Popup"
				},
				{
					"type": "checkbox",
					"id": "enable_video",
					"label": "Show video",
					"default": false
				},
				{
					"type": "video_url",
					"id": "video_link",
					"label": "Video link",
					"accept": [
						"youtube",
						"vimeo"
					],
					"default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
					"info": "Video links from YouTube or Vimeo accepted."
				},
				{
					"type": "select",
					"id": "video_button_color",
					"label": "Color",
					"default": "text--white",
					"options": [
						{
							"value": "text--neutral",
							"label": "Normal text"
						},
						{
							"value": "text--white",
							"label": "White"
						},
						{
							"value": "text--primary",
							"label": "Primary accent"
						},
						{
							"value": "text--secondary",
							"label": "Secondary accent"
						},
						{
							"value": "text--black",
							"label": "Black"
						},
						{
							"value": "text--invert--primary",
							"label": "Primary dark accent"
						},
						{
							"value": "text--invert--secondary",
							"label": "Secondary dark accent"
						},
						{
							"value": "text--invert",
							"label": "Inverted text color"
						},
						{
							"value": "text--bright--primary",
							"label": "Primary bright accent"
						},
						{
							"value": "text--bright--secondary",
							"label": "Secondary bright accent"
						}
					]
				}
			]
		}
	],
	"presets": [
		{
			"name": "Text columns with images",
			"blocks": [
				{
					"type": "text_block"
				},
				{
					"type": "text_block"
				},
				{
					"type": "text_block"
				}
			]
		}
	],
	"disabled_on": {
		"groups": [
			"header",
			"aside"
		]
	}
}
{% endschema %}
