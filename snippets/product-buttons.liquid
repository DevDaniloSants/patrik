<!-- /snippets/product-buttons.liquid -->

{%- liquid
  assign buybutton_setting = false
  assign gift_card_recipient_feature_active = false
  assign current_variant = product.selected_or_first_available_variant

  if block.settings.enable_gift_card_recipient and product.gift_card?
    assign gift_card_recipient_feature_active = true
  endif

  comment
    Quick buy buttons are incompatable with gift card products and subscription products
  endcomment
  if block.settings.enable_payment_button and gift_card_recipient_feature_active == false
    assign buybutton_setting = true
  endif
  if product.selling_plan_groups.size > 0
    assign buybutton_setting = false
  endif
-%}

<div class="product__block__buttons" style="--PB: {{ block.settings.padding_bottom }}px;" {{ block.shopify_attributes }} >
  <div data-product-form-outer>
    {% comment %} The [data-product-form] tag distinguishes the product form from upsell instant-add-buttons. {% endcomment %}
    {%- form 'product', product, id: uniq_id, data-product-form: '', data-product-handle: product.handle -%}
      {%- unless hidden -%}
        <div class="product__form__inner" data-form-inner>

          {% comment %}
            Note: the gift card recipient form is controlled in Checkout and must contain these undocumented line item propeties:
            * properties[__shopify_send_gift_card_to_recipient] - Hidden - Toggles the feature on/off in checkout, following properties have no effect without it
            * properties[Recipient email] - The email of the gift card recipient
            * properties[Recipient name] - The name of the gift card recipient
            * properties[Message] - Shopify chose a highly generic name for the gift card message, this could easily conflict with an app or custom code
          {% endcomment %}
          {%- if gift_card_recipient_feature_active -%}
            {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
          {%- endif -%}

          <div class="product__submit" data-buttons-wrapper data-add-action-wrapper data-error-boundary>
            <div data-error-display role='alert' class="add-action-errors"></div>

            {%- assign button_text = 'products.product.add_to_cart' | t -%}
            {%- if product.metafields.theme.preorder.value == true -%}
              {% comment %} Add a line item property with 'Sale type: Pre-order' and make the button say 'Pre-order'{% endcomment %}
              <input type="hidden" data-product-preorder name="properties[{{ 'products.product.sale_type' | t }}]" value="{{ 'products.product.pre_order' | t }}">
              {%- assign button_text =  'products.product.pre_order' | t -%}
            {%- endif -%}

            {%- render 'sibling-color-as-line-prop' product: product -%}

            {%- if current_variant == null -%}
              {%- assign button_text =  'products.product.unavailable' | t -%}
            {%- endif -%}

            {%- if current_variant.available == false -%}
              {%- assign button_text =  'products.product.sold_out' | t -%}
            {%- endif -%}

            <div class="product__submit__buttons {% if product.has_only_default_variant %} product__submit__buttons--clear{% endif %}">
              <span class="sr-only" aria-live="polite" x-show="isLoading">
                {{ 'products.product.adding_to_cart' | t }}
              </span>
              <span class="sr-only" aria-live="polite" x-show="isSuccess">
                {{ 'products.product.added_to_cart' | t }}
              </span>

              <button
                type="submit"
                name="add"
                id="btn--add-to-cart"
                class="btn--outline max-h-[40px]! btn--full btn--primary px-[67px]! btn--add-to-cart lg:min-h-[54px] bottom-[50%] !border-none !rounded-full !bg-white border-none md:!bg-black !w-fit md:!w-full !text-black md:!text-white"
                data-add-to-cart
                onclick="
                  if (window.innerWidth < 1024) {
                    event.preventDefault();
                    event.stopPropagation();
                    var form = this.closest('form');
                    var input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'return_to';
                    input.value = '/cart';
                    form.appendChild(input);
                    form.submit();
                  }
                "
                {% comment %} Explicitly add aria label so that button text isn't read out in screen readers in uppercase {% endcomment %}
                aria-label="{{ button_text }}"
                :class="{
                  'has-success': isSuccess,
                  'loading': isLoading
                }"
                {% unless current_variant.available %} disabled="disabled" {% endunless %}
              >
                <span class="btn-state-ready flex justify-center rounded-full! relative bottom-[2px] lg:bottom-0">
                  <span data-add-to-cart-text>
                    {{ button_text }}
                  </span>
                  {% if current_variant %}
                    <p></p>
                  {% endif %}
                </span>

                <span class="btn-state-loading">
                  <svg height="18" width="18" class="svg-loader">
                    <circle r="7" cx="9" cy="9" />
                    <circle stroke-dasharray="87.96459430051421 87.96459430051421" r="7" cx="9" cy="9" />
                  </svg>
                </span>

                <span class="btn-state-complete">&nbsp;</span>
              </button>

              {%- if buybutton_setting -%}
                <div class="product__submit__quick">
                  {{ form | payment_button }}
                </div>
              {%- endif -%}
            </div>

            {%- comment -%} Botão "Comprar com um especialista" {%- endcomment -%}
            <div class="flex w-full mt-2">
              {%- render 'specialist-open-modal-button', uniq_id: uniq_id -%}
            </div>
          </div>
        </div>

        {% comment %} Shop pay split payment terms {% endcomment %}
        <div class="shop-pay-terms">{{- form | payment_terms -}}</div>
      {%- endunless -%}

      {% comment %} The input with name="id" indicates the variant to add to cart {% endcomment %}
      <input type="hidden" name="id" x-model.fill="variantId" value="{{ current_variant.id }}">
    {%- endform -%}
  </div>
</div>

{%- unless hidden -%}
{%- comment -%} Modal de Escolha de Canal — Comprar com um Especialista {%- endcomment -%}
<div
  id="specialist-modal-{{ uniq_id }}"
  role="dialog"
  aria-modal="true"
  aria-label="Escolha um canal de contato"
  style="display:none; position:fixed; inset:0; z-index:99999; align-items:center; justify-content:center; padding:16px;"
  onclick="if(event.target===this){this.classList.remove('specialist-modal--open');this.style.display='none';}"
>
  <!-- Backdrop -->
  <div style="position:absolute; inset:0; background:rgba(0,0,0,0.45); backdrop-filter:blur(2px);"></div>

  <!-- Card -->
  <div class="specialist-modal__card lg:rounded-[20px]!" style="position:relative; background:#fff; padding:36px 32px 28px; max-width:420px; width:100%; text-align:center;">
    <!-- Handle mobile -->
    <div class="specialist-modal__handle" style="display:none; width:36px; height:4px; background:#ddd; border-radius:9999px; margin:0 auto 20px;"></div>
    <!-- Fechar -->
    <button
      type="button"
      aria-label="Fechar"
      onclick="var m=this.closest('[id^=specialist-modal-]');if(m){m.classList.remove('specialist-modal--open');m.style.display='none';}"
      style="position:absolute; top:13px; right:16px; background:none; border:none; cursor:pointer; color:#666; padding:4px; display:flex; align-items:center;"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <!-- Ícone decorativo -->
    {% comment %} <div style="width:52px; height:52px; background:#f0f0f0; border-radius:50%; margin:0 auto 16px; display:flex; align-items:center; justify-content:center;">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/>
      </svg>
    </div> {% endcomment %}

    <span style="font-size:14px; font-weight:600; color:#111; margin:0 0 8px; line-height:1.3;">Escolha um canal de contato de sua preferência</span>

    <!-- Botão WhatsApp -->
    <a
      id="btn--specialist-whatsapp"
      href="{{ block.settings.whatsapp_number | default: 'https://wa.me/5511999999999' }}"
      target="_blank"
      rel="noopener noreferrer"
      onclick="var m=this.closest('[id^=specialist-modal-]');if(m){m.classList.remove('specialist-modal--open');m.style.display='none';}"
      style="display:flex; margin-top: 15px; align-items:center; justify-content:center; gap:10px; width:100%; padding:14px 20px; background:#25D366; color:#fff; border-radius:9999px; font-size:14px; font-weight:600; text-decoration:none; margin-bottom:12px; transition:background 0.2s, transform 0.15s;"
      onmouseover="this.style.background='#20bf5b'; this.style.transform='translateY(-1px)';"
      onmouseout="this.style.background='#25D366'; this.style.transform='translateY(0)';"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0;">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Falar pelo WhatsApp
    </a>

    <!-- Botão Chat -->
    <button
      id="btn--specialist-chat"
      type="button"
      data-chat-open-btn
      style="display:flex; align-items:center; justify-content:center; gap:10px; width:100%; padding:14px 20px; background:#111; color:#fff; border-radius:9999px; font-size:14px; font-weight:600; border:none; cursor:pointer; transition:background 0.2s, transform 0.15s; box-shadow:0 4px 14px rgba(0,0,0,0.15);"
      onmouseover="this.style.background='#333'; this.style.transform='translateY(-1px)';"
      onmouseout="this.style.background='#111'; this.style.transform='translateY(0)';"
      onclick="var m=document.querySelector('[id^=specialist-modal-].specialist-modal--open');if(m){m.querySelector('.specialist-modal__card').style.display='none';m.querySelector('[style*=backdrop-filter]').style.display='none';m.classList.remove('specialist-modal--open');m.style.display='none';} specialistOpenChat();"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"/>
      </svg>
      Falar pelo Chat
    </button>
  </div>
</div>

<style>
  [id^="specialist-modal-"] { display: none; }
  [id^="specialist-modal-"].specialist-modal--open { display: flex !important; }

  #btn--specialist:hover {
    background: #000 !important;
    color: #fff !important;
  }

  /* Desktop: modal centrado */
  @media (min-width: 768px) {
    [id^="specialist-modal-"] {
      align-items: center;
    }
    [id^="specialist-modal-"] .specialist-modal__card {
      transform: translateY(40px);
      opacity: 0;
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.25s ease;
    }
    [id^="specialist-modal-"].specialist-modal--open .specialist-modal__card {
      transform: translateY(0);
      opacity: 1;
    }
  }

  /* Mobile: bottom sheet */
  @media (max-width: 767px) {
    [id^="specialist-modal-"] {
      align-items: flex-end !important;
      padding: 0 !important;
    }
    [id^="specialist-modal-"] .specialist-modal__card {
      max-width: 100% !important;
      width: 100% !important;
      padding: 20px 24px 32px !important;
      transform: translateY(100%);
      transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    }
    [id^="specialist-modal-"].specialist-modal--open .specialist-modal__card {
      transform: translateY(0);
    }
    [id^="specialist-modal-"] .specialist-modal__handle {
      display: block !important;
    }
  }
</style>

<script>
  (function() {
    // Teleporta o modal para o body para escapar de qualquer containment CSS (transform, overflow, etc.)
    var modalId = 'specialist-modal-{{ uniq_id }}';
    function teleportModal() {
      var modal = document.getElementById(modalId);
      if (modal && modal.parentNode !== document.body) {
        document.body.appendChild(modal);
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', teleportModal);
    } else {
      teleportModal();
    }

    function specialistOpenChat() {
      var inboxChat = document.querySelector('inbox-online-store-chat') || window.ShopifyChat;
      if (inboxChat && inboxChat.tagName && inboxChat.tagName.toLowerCase() === 'inbox-online-store-chat') {
        inboxChat.setAttribute('is-open', 'true');
        if (inboxChat.shadowRoot) {
          var shadowBtn = inboxChat.shadowRoot.querySelector('button');
          if (shadowBtn) shadowBtn.click();
        }
      }
    }
    window.specialistOpenChat = specialistOpenChat;

    // Fecha modal com ESC
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        var modal = document.querySelector('[id^="specialist-modal-"].specialist-modal--open');
        if (modal) modal.classList.remove('specialist-modal--open');
      }
    });
  })();
</script>
{%- endunless -%}
