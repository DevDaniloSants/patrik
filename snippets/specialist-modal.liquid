{%- comment -%}
  Componente: specialist-modal.liquid

  Props:
    - modal_id      (obrigatório) — ID único do modal, ex: 'specialist-modal-{{ uniq_id }}'
    - whatsapp_url  (opcional)   — URL completa do WhatsApp, ex: 'https://wa.me/5521974956097'
{%- endcomment -%}

{%- liquid
  assign sm_modal_id     = modal_id
  assign sm_whatsapp_url = whatsapp_url | default: 'https://wa.me/5521974956097'
-%}

<div
  id="{{ sm_modal_id }}"
  role="dialog"
  aria-modal="true"
  aria-label="Escolha um canal de contato"
  style="display:none; position:fixed; inset:0; z-index:99999; align-items:center; justify-content:center; padding:16px;"
  onclick="if(event.target===this){this.classList.remove('specialist-modal--open');this.style.display='none';}">

  <!-- Backdrop -->
  <div style="position:absolute; inset:0; background:rgba(0,0,0,0.45); backdrop-filter:blur(2px);"></div>

  <!-- Card -->
  <div class="specialist-modal__card lg:rounded-[20px]!" style="position:relative; background:#fff; padding:36px 32px 28px; max-width:420px; width:100%; text-align:center;">
    <!-- Handle mobile -->
    <div class="specialist-modal__handle" style="display:none; width:36px; height:4px; background:#ddd; border-radius:9999px; margin:0 auto 20px;"></div>

    <!-- Fechar -->
    <button
      type="button"
      aria-label="Fechar"
      onclick="var m=this.closest('[id^=specialist-modal-]');if(m){m.classList.remove('specialist-modal--open');m.style.display='none';}"
      style="position:absolute; top:13px; right:16px; background:none; border:none; cursor:pointer; color:#666; padding:4px; display:flex; align-items:center;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <span style="font-size:14px; font-weight:600; color:#111; margin:0 0 8px; line-height:1.3;">Escolha um canal de contato de sua preferência</span>

    <!-- Botão WhatsApp -->
    <a
      href="{{ sm_whatsapp_url }}"
      target="_blank"
      rel="noopener noreferrer"
      onclick="var m=this.closest('[id^=specialist-modal-]');if(m){m.classList.remove('specialist-modal--open');m.style.display='none';}"
      style="display:flex; margin-top:15px; align-items:center; justify-content:center; gap:10px; width:100%; padding:14px 20px; background:#25D366; color:#fff; border-radius:9999px; font-size:14px; font-weight:600; text-decoration:none; margin-bottom:12px; transition:background 0.2s, transform 0.15s;"
      onmouseover="this.style.background='#20bf5b'; this.style.transform='translateY(-1px)';"
      onmouseout="this.style.background='#25D366'; this.style.transform='translateY(0)';">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0;">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Falar pelo WhatsApp
    </a>

    <!-- Botão Chat -->
    <button
      type="button"
      style="display:flex; align-items:center; justify-content:center; gap:10px; width:100%; padding:14px 20px; background:#111; color:#fff; border-radius:9999px; font-size:14px; font-weight:600; border:none; cursor:pointer; transition:background 0.2s, transform 0.15s; box-shadow:0 4px 14px rgba(0,0,0,0.15);"
      onmouseover="this.style.background='#333'; this.style.transform='translateY(-1px)';"
      onmouseout="this.style.background='#111'; this.style.transform='translateY(0)';"
      onclick="var m=this.closest('[id^=specialist-modal-]');var msg=m?m.getAttribute('data-specialist-message'):'';if(m){m.classList.remove('specialist-modal--open');m.style.display='none';}window.specialistOpenChat&&window.specialistOpenChat(msg);">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"/>
      </svg>
      Falar pelo Chat
    </button>
  </div>
</div>

<style>
  #{{ sm_modal_id }} { display: none; }
  #{{ sm_modal_id }}.specialist-modal--open { display: flex !important; }

  /* Desktop: modal centrado com animação */
  @media (min-width: 768px) {
    #{{ sm_modal_id }} { align-items: center; }
    #{{ sm_modal_id }} .specialist-modal__card {
      transform: translateY(40px);
      opacity: 0;
      transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.25s ease;
    }
    #{{ sm_modal_id }}.specialist-modal--open .specialist-modal__card {
      transform: translateY(0);
      opacity: 1;
    }
  }

  /* Mobile: bottom sheet */
  @media (max-width: 767px) {
    #{{ sm_modal_id }} { align-items: flex-end !important; padding: 0 !important; }
    #{{ sm_modal_id }} .specialist-modal__card {
      max-width: 100% !important;
      width: 100% !important;
      padding: 20px 24px 32px !important;
      transform: translateY(100%);
      transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    }
    #{{ sm_modal_id }}.specialist-modal--open .specialist-modal__card { transform: translateY(0); }
    #{{ sm_modal_id }} .specialist-modal__handle { display: block !important; }
  }
</style>

<script>
  (function() {
    var modalId = '{{ sm_modal_id }}';

    // Teleporta para o body para escapar de containment CSS
    function teleportModal() {
      var modal = document.getElementById(modalId);
      if (modal && modal.parentNode !== document.body) {
        document.body.appendChild(modal);
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', teleportModal);
    } else {
      teleportModal();
    }

    // Fecha com ESC
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        var modal = document.getElementById(modalId);
        if (modal && modal.classList.contains('specialist-modal--open')) {
          modal.classList.remove('specialist-modal--open');
          modal.style.display = 'none';
        }
      }
    });

    // Registra specialistOpenChat globalmente (só uma vez)
    if (!window.specialistOpenChat) {
      window.specialistOpenChat = function(msg) {
        var inboxChat = document.querySelector('inbox-online-store-chat') || window.ShopifyChat;
        if (inboxChat && inboxChat.tagName && inboxChat.tagName.toLowerCase() === 'inbox-online-store-chat') {
          inboxChat.setAttribute('is-open', 'true');
          if (inboxChat.shadowRoot) {
            var shadowBtn = inboxChat.shadowRoot.querySelector('button');
            if (shadowBtn) shadowBtn.click();
          }
          if (msg) {
            var attempts = 0;
            var interval = setInterval(function() {
              attempts++;
              var sr = inboxChat.shadowRoot;
              var input = sr && (sr.querySelector('textarea') || sr.querySelector('input[type="text"]'));
              if (input) {
                clearInterval(interval);
                input.focus();
                var setter = Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype, 'value') ||
                             Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value');
                if (setter) setter.set.call(input, msg);
                else input.value = msg;
                input.dispatchEvent(new Event('input', { bubbles: true }));
                input.dispatchEvent(new Event('change', { bubbles: true }));
              } else if (attempts >= 20) {
                clearInterval(interval);
              }
            }, 200);
          }
        }
      };
    }
  })();
</script>
